    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ናሁ፡ ወጠንኩ፡ ሰቆቃወ፡ ሥጋ፡ ግሱስ፨</l>
            <l n="2">ተላዌ፡ ሰቆቃው፡ ዘነፍስ፨</l>
            <l n="3">ባሕቱ፡ ብሂለ፡ ኢትበለኒ፡ ክርስቶስ፨</l>
            <l n="4">ለምንት፡ ትነብብ፡ በአፉከ፡ እንዘ፡ ልብከ፡ ግሑሥ፨</l>
            <l n="5">እምገቢረ፡ ዓሥር፡ ትእዛዝ፡ ወቃላት፡ ሳድስ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ኦሥጋየ፡ መፍቀሪተ፡ ብዕል፡ ቅሡም፨</l>
            <l n="2">ወሰትየ፡ ስቴ፡ ጥዑም፨</l>
            <l n="3">ለምንት፡ ለኪ፡ አጽርዖተ፡ ጸሎት፡ ወጾም፨</l>
            <l n="4">እንዘ፡ የአምር፡ ሕሊናኪ፡ ብዕለ፡ ተድላ፡ ዝንቱ፡ ዓለም፨</l>
            <l n="5">ከመ፡ በጽላሎት፡ ተመስለ፡ ወዓዲ፡ በሕልም፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ኦሥጋየ፡ ይደልወኪ፡ ንስሐ፨</l>
            <l n="2">እምሥዕርተ፡ ርእስኪ፡ ነዋኅ፡ አምጣነ፡ ጌጋይኪ፡ ኖኃ፨</l>
            <l n="3">መፍትውኑ፡ ገቢረ፡ ሐሤት፡ ወፍሥሐ፨</l>
            <l n="4">እንዘ፡ በዝየ፡ መልአከ፡ ሞት፡ ይጸንሐኪ፡ ጸኒሐ፨</l>
            <l n="5">ወገሃነም፡ በከሐ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ኦሥጋየ፡ ኢይበቍዓኪ፡ ምንተ፨</l>
            <l n="2">[line missing]</l>
            <l n="3">ከመዝ፡ አኮኑ፡  ፈጣሪ፡ እንበለ፡ ትዘከሪ፡ ሞተ፨</l>
            <l n="4">በቀትረ፡ መዐልት፡ እመሂ፡ ሌሊተ፨</l>
            <l n="5">አምሳለ፡ ሰራቂ፡ ይመጽእ፡ ወይበጽሕ፡ ግብተ፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ኦሥጋየ፡ ለእመ፡ ብኪ፡ ልባዌ፨</l>
            <l n="2">ተዘከሪ፡ ዮም፡ ገቢረ፡ ሰማያዌ፨</l>
            <l n="3">በዓለምሰ፡ ካልእተ፡ ሀገር፡ ነነዌ፨</l>
            <l n="4">ተዘክሮ፡ ብዕል፡ ወኀሢሠ፡ ብዙኅ፡ ሥጋዌ፨</l>
            <l n="5">ያመጽእ፡ በላዕለ፡ ነፍስ፡ ሕማመ፡ ወደዌ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ኦሥጋየ፡ ለመብልዓ፡ ዓለም፡ ዝንቱ፨</l>
            <l n="2">ምንት፡ ረባሑ፡ ወምንት፡ በቍዔቱ፨</l>
            <l n="3">አኮኑ፡ የዓኪ፡ ወይጸላዕ፡ በደኃሪቱ፨</l>
            <l n="4">ጊዜ፡ ጽምዕ፡ ይገድፍዎ፡ እንዘ፡ ይጸይእ፡ ውእቱ፨</l>
            <l n="5">አምሳለ፡ ገደፍዎሙ፡ ለአካል፡ ባሕቱ፡ ዘሞቱ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ኦሥጋየ፡ ለለመዋዕል፡ ወጊዜ፨</l>
            <l n="2">ታፈድፍዲ፡ ጌጋየ፡ እስከ፡ ዘመን፡ ማእዜ፨</l>
            <l n="3">ኢለበውኪኑ፡ ገቢረ፡ ኃጢአት፡ ዘይእዜ፨</l>
            <l n="4">ከመ፡ ያበጽሕ፡ በደኃሪ፡ ውስተ፡ ጽኑዕ፡ እንባዜ፨</l>
            <l n="5">መንገለ፡ ኢሀሎ፡ ትፍሥሕት፡ ወአልቦ፡ ኑዛዜ፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ኦሥጋየ፡ እመሌሊት፡ አሐደ፨</l>
            <l n="2">ሶበ፡ አኀዘኪ፡ ደዌ፡ ዘተሐምሚ፡ ፈድፋደ፨</l>
            <l n="3">እፎ፡ ደኃሪ፡ ይከውኑ፡ ክቡደ፨</l>
            <l n="4">ኀቤኪ፡ ፈጣሪ፡ ጊዜ፡ ይፈኑ፡ ፈቀደ፨</l>
            <l n="5">ዕፄ፡ መፍርሃ፡ ወግሩመ፡ ነደ፨</l>

          </lg>
          
          <lg type="stanza" n="9">
            
            <l n="1">ኦሥጋየ፡ እንዘ፡ ቃለ፡ ወንጌል፡ ይብል፨</l>
            <l n="2">በዲበ፡ ክሳዱ፡ ዘኢጾረ፡ አርዑተ፡ መስቀሉ፡ ለቃል፨</l>
            <l n="3">መንግሥተ፡ ሰማያትሃ፡ ከመ፡ ይትዋረሳ፡ ኢይክል፨</l>
            <l n="4">ለምንት፡ ተሐሥሢ፡ ጸዋትወ፡ ሕይወት፡ ወብዕል፨</l>
            <l n="5">ዘደኃሪቶሙ፡ ምንዳቤ፡ ወሐጕል፨</l>

          </lg>
          
          <lg type="stanza" n="10">
            
            <l n="1">ኦሥጋየ፡ መናኒተ፡ ገድል፡ ወምናኔ፨</l>
            <l n="2">ዓዲ፡ መዝገበ፡ ዘኢያማሰኖ፡ ቍንቍኔ፨</l>
            <l n="3">እስከ፡ ማእዜኑ፡ አልባሰ፡ ትሬስዪ፡ ልብሰ፡ ግማኔ፨</l>
            <l n="4">እንዘ፡ ይዴለው፡ ሕይወትኪ፡ በጽንዓ፡ ፃዕረ፡ ሞት፡ ማኔ፨</l>
            <l n="5">ወይጸንሐኪ፡ ፈድፋደ፡ ኵነኔ፨</l>

          </lg>
          
          <lg type="stanza" n="11">
            
            <l n="1">ኦሥጋየ፡ መፍቀራተ፡ ወይን፡ ወሥጋ፨</l>
            <l n="2">ኵሎ፡ ጊዜ፡ እንበለ፡ ሕፀፅ፡ ወግብረ፡ ንትጋ፨</l>
            <l n="3">ምንትኑ፡ በዓለም፡ ረኪበ፡ ጸጋ፨</l>
            <l n="4">አኮኑ፡ ያቀውም፡ በፍርሃት፡ ማእከለ፡ ግሩም፡ እንግልጋ፨</l>
            <l n="5">ወየዓሥር፡ ነፍሳ፡ ከመ፡ ሐብል፡ ወጋጋ፨</l>

          </lg>
          
          <lg type="stanza" n="12">
            
            <l n="1">ኦሥጋየ፡ ዘተሠርገውኪ፡ ዝንጋዔ፨</l>
            <l n="2">ከመ፡ እለ፡ አልቦሙ፡ ተስፋ፡ ትንሣኤ፨</l>
            <l n="3">ትጐይዪ፡ ውስተ፡ ዓውደ፡ ፍትሕ፡ ቅድመ፡ ጉባኤ፨</l>
            <l n="4">በዓለ፡ ገራህት፡ እምተዋሕዶ፡ ለኀበ፡ ከዊነ፡ ክልኤ፨</l>
            <l n="5">አመ፡ ክርዳዳተ፡ እምስርናይ፡ ይፈልጥ፡ በመስዔ፨</l>

          </lg>
          
          <lg type="stanza" n="13">
            
            <l n="1">ኦሥጋየ፡ ዘሕሊና፡ ዚአኪ፡ አብደ፨</l>
            <l n="2">ልብኪኒ፡ ከመ፡ ፈርዖን፡ ከብደ፨</l>
            <l n="3">እስፍንተ፡ ዘመነ፡ ወመዋዕለ፡ ፈድፋደ፨</l>
            <l n="4">ለምንት፡ ኢትሬእዪ፡ እንዘ፡ ይቀትል፡ አሐደ፨</l>
            <l n="5">ወእንዘ፡ አሐደ፡  ያደዊ፡ ፈጣሪ፡ ገሃደ፨</l>

          </lg>
          
          <lg type="stanza" n="14">
            
            <l n="1">ኦሥጋየ፡ እኅተ፡ ነዌ፡ ድሩክ፨</l>
            <l n="2">አኮ፡ አኮ፡ እኅተ፡ አልዓዛር፡ ዓርክ፨</l>
            <l n="3">ጊዜ፡ ንግደትኪ፡ ኮነ፡ ዘእሳት፡ ከመ፡ ንደተ፡ ሣዕር፡ ወሦክ፨</l>
            <l n="4">ኢይክሉ፡ ያቍርሩ፡ ልሳነኪ፡ እምአዕርክት፡ ዓርክ፨</l>
            <l n="5">ወእመላእክት፡ አሐዱ፡ መልአክ፨</l>

          </lg>
          
          <lg type="stanza" n="15">
            
            <l n="1">ኦሥጋየ፡ ኅጥዕተ፡ ንዋም፡ ወድቃስ፨</l>
            <l n="2">በሐልዮ፡ ሲሳይ፡ ወልብስ፨</l>
            <l n="3">ኅድጊሰ፡ ዘለኪ፡ እግዚአብሔር፡ ንጉሥ፨</l>
            <l n="4">አኮኑ፡ ያስተዳሉ፡ ሲሳየ፡ ኵሉ፡ ዘነፍስ፨</l>
            <l n="5">ወለአራዊት፡ ዘሀለዉ፡ ወስተ፡ ባሕር፡ ወየብስ፨</l>

          </lg>
          
          <lg type="stanza" n="16">
            
            <l n="1">ኦሥጋየ፡ ዘባሕርይኪ፡ መዋቲ፨</l>
            <l n="2">ወግማደ፡ መሬት፡ አንቲ፨</l>
            <l n="3">መንግሥተ፡ ሰማያትሃ፡ ሀገረ፡ ጻድቃን፡ ይእቲ፨</l>
            <l n="4">እፎ፡ ጸላእከ፡ ወመነንኪ፡ በአፍቅሮተ፡ ዓለም፡ ዛቲ፨</l>
            <l n="5">ዘትምይንታ፡ ብዙኅ፡ ወፍቅራ፡ መስሓቲ፨</l>

          </lg>
          
          <lg type="stanza" n="17">
            
            <l n="1">በእንቲአኪ፡ ነበብኩ፡ መንፈቀ፡ ሠላሳ፡ ድርሳናት፨</l>
            <l n="2">ኦሥጋየ፡ ድሉተ፡ ኵለንታ፡ ለሞት፨</l>
            <l n="3">ለመጽሐፈ፡ ዜናኪሰ፡ እስከ፡ ፍጻሜ፡ እምጥንት፨</l>
            <l n="4">በረቀ፡ ሰማይ፡ ወበማየ፡ ሕመት፨</l>
            <l n="5">አብሕርት፡ እምኢፈጸምዎ፡ ወብዙኃን፡ ጸሐፍት፨</l>

          </lg>
          
        </div>

        
        
