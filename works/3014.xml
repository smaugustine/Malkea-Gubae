  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ተማሕፀንኩ፡ በሐዊሮትከ፡ ፍናወ፡ ዕለታት፡ ምእቱ፨</l>
            <l n="2">ከመ፡ በሥላሴ፡ ትትአመን፡ እምአምላኮ፡ ጣዖት፡ ከንቱ፨</l>
            <l n="3">ሰማዕት፡ ሖር፡ ድካመ፡ ፍኖትከ፡ ዝንቱ፨</l>
            <l n="4">ይኩነኒ፡ ዕረፍተ፡ ነፍስ፡ ውስተ፡ ሰማያዊት፡ መንግሥቱ፨</l>
            <l n="5">ለዘባሕቲቱ፡ ይነግሥ፡ ወካልእ፡ አልቦቱ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ተማሕፀንኩ፡ በቀዊሞትከ፡ ቅድመ፡ መኰንን፡ ሄርሜንዮስ፨</l>
            <l n="2">ከመ፡ በእንቲአከ፡ ቆመ፡ ቅድመ፡ ጲላጦስ፨</l>
            <l n="3">እንዘ፡ ትዜከሮ፡ በልብ፡ ለንጹሕ፡ ባሕርይ፡ ክርስቶስ፨</l>
            <l n="4">ብፁዕ፡ ሖር፡ ለፍኖትየ፡ መብዕስ፨</l>
            <l n="5">አስተፋጥን፡ አርትዖቶ፡ ውስተ፡ ባሕር፡ ወይብስ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ተማሕፀንኩ፡ በተወይድዮትከ፡ ውስተ፡ ቤተ፡ ሞቅሕ፡ ሙቁሐ፨</l>
            <l n="2">በእንተ፡ ኢየሱስ፡ ክርስቶስ፡ ዘሙቁሓነ፡ ሲኦል፡ ፈትሐ፨</l>
            <l n="3">አስተበቍዐከ፡ ሖር፡ ትትራድአኒ፡ ብዙኀ፨</l>
            <l n="4">ኢይቁም፡ ዐውደ፡ ብካይ፡ አመ፡ ይትወህቦ፡ ፍሥሐ፨</l>
            <l n="5">ለዘዲበ፡ መክሊት፡ ካዕበ፡ መክሊተ፡ አርብሐ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ተማሕፀንኩ፡ በተመትሮቶን፡ ለአእዳዊከ፡ ክልኤሆን፨</l>
            <l n="2">በሰይፈ፡ መኰንን፡ ዐላዊ፡ ዘእስክንድርያ፡ መካን፨</l>
            <l n="3">ንብለከ፡ ሖር፡ አግብርተ፡ ክርስቶስ፡ መድኅን፨</l>
            <l n="4">መግበነ፡ በረድኤትከ፡ እስመ፡ መጋቢ፡ ምእመን፨</l>
            <l n="5">ከመ፡ ንርከብ፡ መክፈልተ፡ ወርስተ፡ ውስተ፡ በአቶሙ፡ ለቅዱሳን፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ተማሕፀንኩ፡ በተዐሥሮትከ፡ ውስተ፡ ሦረ፡ ላህም፡ ድኅሪተ፨</l>
            <l n="2">ወበፈጽሞትከ፡ ህየ፡ ጽጐጐ፡ ሀገር፡ ዐበይተ፨</l>
            <l n="3">ከመ፡ እንሣእ፡ ሖር፡ ዘመንፈስከ፡ ካዕበተ፨</l>
            <l n="4">ሀበኒ፡ ሐሜለተከ፡ እንዘ፡ ታተሉ፡ ረድኤተ፨</l>
            <l n="5">እስመ፡ ከመ፡ ኤልሳዕ፡ አነ፡ ወኤልያስ፡ አንተ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ተማሕፀንኩ፡ በጸዊሮትከ፡ ከመ፡ እሳት፡ ዘይነድድ፨</l>
            <l n="2">አምሳለ፡ አክሊል፡ ዲበ፡ ርእስ፡ ፃሕለ፡ ኀጺን፡ ክቡድ፨</l>
            <l n="3">ከመ፡ ጸለይከ፡ ሖር፡ ለሐራ፡ መኰንን፡ አብድ፨</l>
            <l n="4">ቀተልኮሙ፡ እምሕይወቶሙ፡ በኀይለ፡ አምላክከ፡ ወልድ፨</l>
            <l n="5">ሕይወተ፡ ፀርየ፡ ኰንን፡ ወቅትል፡ በዐውድ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ተማሕፀንኩ፡ በስትዮትከ፡ ፍሉሐ፡ ኵለንታ፡ ዐረረ፨</l>
            <l n="2">እንዘ፡ በእንተ፡ ጽድቅ፡ ትትዔገሥ፡ ምንዳቤያተ፡ ወጻዕረ፨</l>
            <l n="3">ጻድቅ፡ ሖር፡ ለዘእስእለከ፡ ወትረ፨</l>
            <l n="4">ምርሐኒ፡ ፍኖተ፡ ጽድቅ፡ ወአለብወኒ፡ ምክረ፨</l>
            <l n="5">በዓለመ፡ ሕይወት፡ እንግሥ፡ ምስሌከ፡ ኅቡረ፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ተማሕፀንኩ፡ በተገድፎትከ፡ ውስተ፡ ግበ፡ ሥቃይ፡ ግሩም፨</l>
            <l n="2">ዘውሣጤሁ፡ አክይስት፡ ወአንበሳ፡ መፍርህ፡ ገዳም፨</l>
            <l n="3">ባርከኒ፡ ሖር፡ በበረከት፡ ፍጹም፨</l>
            <l n="4">እግዚአብሔር፡ ንጉሠ፡ ከዋላ፡ ወፍጽም፨</l>
            <l n="5">ውስተ፡ ቤተ፡ ነፍስየ፡ ይኅድር፡ ለወልድከ፡ ሴም፨</l>

          </lg>
          
          <lg type="stanza" n="9">
            
            <l n="1">ተማሕፀንኩ፡ በስኪቦትከ፡ መልዕልተ፡ ዐራት፡ ዘብርት፨</l>
            <l n="2">እንዘ፡ ታሕቴሁ፡ ንጹፍ፡ ፍሕመ፡ ነዳዲ፡ እሳት፨</l>
            <l n="3">መንክረ፡ ሥቃይ፡ ሖር፡ ወትሩፈ፡ ዕበይ፡ ሰማዕት፨</l>
            <l n="4">ሐዲስ፡ ሐራዊ፡ በሃይማኖት፡ ርትዕት፨</l>
            <l n="5">ከማከ፡ ረስየኒ፡ ለክርስቶስ፡ ሐይወት፨</l>

          </lg>
          
          <lg type="stanza" n="10">
            
            <l n="1">ተማሕፀንኩ፡ በተልዕሎትከ፡ ውስተ፡ መካን፡ ልዑል፨</l>
            <l n="2">እስከ፡ ይመክሩ፡ ብከዕፀበ፡ ኵነኔ፡ ወገድል፨</l>
            <l n="3">ሠራዊተ፡ ጣዖት፡ አጵሎን፡ ወካህናቲሁ፡ ለምስል፨</l>
            <l n="4">ዮሐንስ፡ ሖር፡ ሰባኬ፡ ሐዲስ፡ ወንጌል፨</l>
            <l n="5">አብስረኒ፡ ሥጋዌሁ፡ ለክርስቶስ፡ ቃል፨</l>

          </lg>
          
          <lg type="stanza" n="11">
            
            <l n="1">ተማሕፀንኩ፡ በደመ፡ ስምዐ፡ ለእምከ፡ ዲቦራ፨</l>
            <l n="2">ዘአብሰረተከ፡ ሖር፡ ፍጻሜ፡ ስምዕከ፡ ድኅረ፡ መከራ፨</l>
            <l n="3">ከመ፡ ታኅድረኒ፡ ሊተ፡ ውስተ፡ ሰማያዊት፡ ደብተራ፨</l>
            <l n="4">ወታንብር፡ ዲበ፡ ርእስየ፡ ዕሤተ፡ ገድልከ፡ ጌራ፨</l>
            <l n="5">ብርሃነ፡ ፀሓይ፡ ዘይመስል፡ ሕብራ፨</l>

          </lg>
          
          <lg type="stanza" n="12">
            
            <l n="1">ተማሕፀንኩ፡ በዕርገትከ፡ ውስተ፡ ጤገነ፡ ዘይት፡ ፍሉሕ፨</l>
            <l n="2">ወበትረግዞትከ፡ ህየ፡ በኲናተ፡ ኀጺን፡ ነዊኅ፨</l>
            <l n="3">ቅዱስ፡ ሖር፡ ሰማዕተ፡ ክርስቶስ፡ ስቡሕ፨</l>
            <l n="4">አድኅነኒ፡ ወባልሐኒ፡ እምግርማ፡ ሲኦል፡ መፍርህ፨</l>
            <l n="5">አመ፡ እምኃጥኣን፡ ይገብእ፡ ለጻድቃን፡ ፍትሕ፨</l>

          </lg>
          
        </div>

        <div type="textpart" xml:id="tarafa-malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለከ፡ ሥጋ፡ መሐዋዊ፡ ሥጋከ፡ ለመላኪሃ፡ ክርስቶስ፨</l>
            <l n="2">እስመ፡ አሥመረቶ፡ ሖር፡ በሥርዓተ፡ ነፍስ፨</l>
            <l n="3">አንሶሰውከ፡ በፍና፡ ንግሥ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለከ፡ ለመጽሐፈ፡ ዳዊት፡ መዝሙር፡ እንዘ፡ ትሬስዮ፡ በጽድቅ፨</l>
            <l n="2">ዝሙረ፡ ቃልከ፡ ሖር፡ በዐውደ፡ ስላቅ፨</l>
            <l n="3">ኢሰገድከ፡ ለምስለ፡ ወርቅ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለከ፡ ሐራ፡ መኰንን፡ ሐርየ፡ በጸሎትከ፡ ቅድስት፨</l>
            <l n="2">ሰምዕተ፡ መንክራት፡ ሖር፡ ውስተ፡ ዐውደ፡ ቅስት፨</l>
            <l n="3">ይኩኑ፡ ከመ፡ አብድንት፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለከ፡ መንገለ፡ ምሁረ፡ ኮንከ፡ ቃለ፡ መጽሐፍ፡ ወንጌል፨</l>
            <l n="2">ኢያኅዘነከ፡ ሖር፡ ተመትሮ፡ አባል፨</l>
            <l n="3">እምትትሐጐል፡ ውስተ፡ ሲኦል፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለከ፡ ለሕምዘ፡ አክይስት፡ ቀታሊ፡ ወኀይለ፡ አንበሳ፡ ኪያከ፨</l>
            <l n="2">እስመ፡ ኢወሀበ፡ ሖር፡ ኀይለ፡ አምላክከ፨</l>
            <l n="3">መኰንነ፡ አስተኀፈርከ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለከ፡ ርኢኩከ፡ ሠናየ፡ ሶበ፡ ትቤለከ፡ እም፨</l>
            <l n="2">ተጋደልከ፡ ሖር፡ ዘእንበለ፡ ዐቅም፨</l>
            <l n="3">ወአጥባዕከ፡ ለስምዐ፡ ደም፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለከ፡ እንዘ፡ ርእሰከ፡ ተዐትብ፡ በትእምርተ፡ መስቀል፡ ቅዱስ፨</l>
            <l n="2">ዘፈጸምከ፡ በትረ፡ በዐውደ፡ ኂስ፨</l>
            <l n="3">ውስተ፡ ዓለምከ፡ ሖር፡ መንግሥተ፡ ክርስቶስ፨</l>
            <l n="4">ዕሥየኒ፡ ዕሤተ፡ ዘነፍስ፨</l>

          </lg>
          
        </div>
        
      </div>
    </body>
    
