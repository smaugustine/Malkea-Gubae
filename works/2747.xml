  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለስምክሙ፡ ዘፍትው፡ ዝክሩ፨</l>
            <l n="2">ወለሥዕርትክሙ፡ ሰላም፡ ዘሕብረ፡ ሜላት፡ ሕብሩ፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ለዘጸውዓክሙ፡ መንገለ፡ ክብሩ፨</l>
            <l n="4">ግሩም፡ ግብርከ፡ ይበልዎ፡ ሕዝበ፡ ቤተ፡ ልሄም፡ ሀገሩ፨</l>
            <l n="5">ለእጓለ፡ እመ፡ ሕያውሂ፡ መንክሮ፡ ይንግሩ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለርእስክሙ፡ ዘተሳለቅዎ፡ ሐራ፨</l>
            <l n="2">ወለገጽክሙ፡ ኅትው፡ ማኅቶተ፡ ተቅዋም፡ ክብረ፡ ይብደራ፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ለእንተ፡ ተወልደት፡ እምቤተ፡ ቅስራ፨</l>
            <l n="4">በእንተ፡ መንግሥቱ፡ ለእግዚአብሔር፡ በኵራ፨</l>
            <l n="5">መንክር፡ ላዕሌክሙ፡ ዘበጽሐ፡ መክራ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለቀራንብቲክሙ፡ እለ፡ ይቀጽባ፡ ኂሩተ፨</l>
            <l n="2">ወለዐይንክሙ፡ ሰላም፡ ዘንጻሬሁ፡ ተአኵተ፨</l>
            <l n="3">እምቅድመ፡ ጊዜ፡ ሕፃናት፡ ዘሠለጥክሙ፡ መዊተ፨</l>
            <l n="4">ዘእንበሌክሙ፡ ሰማያዊተ፡ ማሕሌተ፨</l>
            <l n="5">ከመ፡ ዘየአምር፡ አልቦ፡ ዮሐንስ፡ ከሠተ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለአእዛኒክሙ፡ አናቅጸ፡ ሰሚዕ፡ ቅድው፨</l>
            <l n="2">ወለመላትሒክሙ፡ ቀይሕ፡ ከመ፡ ጽጌ፡ ረዳ፡ ፍትው፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ በእንተ፡ ክርስቶስ፡ ሕያው፨</l>
            <l n="4">ማየ፡ ደምክሙ፡ አመ፡ ምግበ፡ ሄሮድስ፡ ዕልው፨</l>
            <l n="5">ዘበውስቴቱ፡ ኢውሕዘ፡ ኢተረክበ፡ በድው፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለአእናፊክሙ፡ እለ፡ መዐዛ፡ ምድር፡ ኢይጼነዋ፨</l>
            <l n="2">ለከናፍሪክሙሂ፡ እለ፡ በሥቃይ፡ መጽለዋ፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ እማቲክሙ፡ ፈተዋ፨</l>
            <l n="4">ኪያክሙ፡ እምቅድመ፡ ሞት፡ አጥባቲሆን፡ ያጥብዋ፨</l>
            <l n="5">ወአመ፡ ተምኔቶን፡ ኢኮነ፡ በኀዘን፡ ጸመዋ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለአፉክሙ፡ አፈ፡ በረከት፡ ሠናይ፨</l>
            <l n="2">ወለአስናኒክሙ፡ ሰላም፡ ዘኢያፅረሶን፡ ጌጋይ፨</l>
            <l n="3">ሕፃናት፡ ንጹሓን፡ መላእክተ፡ ልዑል፡ ሰማይ፨</l>
            <l n="4">ተፈጸመ፡ በሞትክሙ፡ በኢየሩሳሌም፡ ዐባይ፨</l>
            <l n="5">ኀዘን፡ ይሠርቅ፡ ዘይቤ፡ ነቢይ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለልሳንክሙ፡ ልሳነ፡ መላእክት፡ ዘአርያም፨</l>
            <l n="2">ወሰላም፡ ካዕበ፡ ለቃልክሙ፡ ግሩም፨</l>
            <l n="3">እስመ፡ ሕፃናት፡ አንትሙ፡ ቀደምተ፡ ሰማዕታት፡ በደም፨</l>
            <l n="4">ለክሙ፡ ዘኢተቀንየ፡ እመንገለ፡ ክብር፡ ፍጹም፨</l>
            <l n="5">አልቦ፡ የማን፡ ወአልቦ፡ ፀጋም፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ሰላም፡ ለእስትንፋስክሙ፡ መዐዛ፡ ኂሩት፡ ወፍቅር፨</l>
            <l n="2">ዓዲ፡ ሰላም፡ ለጕርዔክሙ፡ ክቡር፨</l>
            <l n="3">ሕፃናት፡ ጠቢባን፡ በግዕዘ፡ አርዌ፡ ዘምድር፨</l>
            <l n="4">ነገሥክሙ፡ እምቅድመ፡ ጊዜ፡ ውስተ፡ ዐውደ፡ ጽዮን፡ ደብር፨</l>
            <l n="5">ወህየ፡ ቀደስክምዎ፡ ለዋሕድ፡ ወበኵር፨</l>

          </lg>
          
          <lg type="stanza" n="9">
            
            <l n="1">ሰላም፡ ለክሳድክሙ፡ ዘመተርዎ፡ አይሁድ፨</l>
            <l n="2">ወለመትክፍትክሙ፡ ሰላም፡ ሥርግወ፡ ደም፡ ኤፉድ፨</l>
            <l n="3">ሕፃናት፡ ትኩኑ፡ ሰማዕታተ፡ ክርስቶስ፡ ወልድ፨</l>
            <l n="4">ተጋባእክሙ፡ ውስተ፡ ቤተ፡ ልሔም፡ ዐውድ፨</l>
            <l n="5">እምነ፡ ቤርሳቤሕ፡ ወዳን፡ በትእዛዝ፡ ክቡድ፨</l>

          </lg>
          
          <lg type="stanza" n="10">
            
            <l n="1">ሰላም፡ ለዘባንክሙ፡ እምልብሰ፡ ዓለም፡ ዘተዐርቀ፨</l>
            <l n="2">ወለእንግድዓክሙ፡ ሰላም፡ ዘበደመ፡ ክሳድ፡ ተጠምቀ፨</l>
            <l n="3">ነገሥተ፡ ምድረ፡ ፋርስ፡ ሕፃናት፡ አመ፡ አምኅዎ፡ ወርቀ፨</l>
            <l n="4">ለክርስቶስ፡ ንጉሥክሙ፡ ዘእምከርሠ፡ ድንግል፡ ተዐውቀ፨</l>
            <l n="5">እብነ፡ መከራ፡ ወግፍዕ፡ ላዕሌክሙ፡ ወድቀ፨</l>

          </lg>
          
          <lg type="stanza" n="11">
            
            <l n="1">ሰላም፡ ሰላም፡ ለሕፅነ፡ ዚአክሙ፡ እብል፨</l>
            <l n="2">ወለእዴክሙ፡ ሐራ፡ ዘመሠጥዎ፡ በኀይል፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ሰማዕታተ፡ ሐዲስ፡ ገድል፨</l>
            <l n="4">አመ፡ ትትለሐዩ፡ ቅድመ፡ ማርያም፡ ድንግል፨</l>
            <l n="5">አስተባይጹኒ፡ በጸጋ፡ ወብዕል፨</l>

          </lg>
          
          <lg type="stanza" n="12">
            
            <l n="1">ሰላም፡ ለመዛርዒክሙ፡ አዕፁቀ፡ መትከፍ፡ አርዝ፨</l>
            <l n="2">ወለኵርናዕክሙ፡ ሰላም፡ በቃለ፡ ማሕሌት፡ ሐዋዝ፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ሠናያነ፡ ባሕርይ፡ ወግዕዝ፨</l>
            <l n="4">አጽንዑ፡ ዐቂቦትየ፡ ለገብርክሙ፡ ትኩዝ፨</l>
            <l n="5">አመ፡ ላዕለ፡ ኵሉ፡ ይወፅእ፡ ፩ትእዛዝ፨</l>

          </lg>
          
          <lg type="stanza" n="13">
            
            <l n="1">ሰላም፡ ለእመትክሙ፡ መሥፈርተ፡ ቤተ፡ ንጽሕ፡ ሐብል፨</l>
            <l n="2">ወለእርኅክሙ፡ ስፉሕ፡ ትእምርተ፡ ቅዱስ፡ መስቀል፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ከዋክብተ፡ ሰማይ፡ ልዑል፨</l>
            <l n="4">ይምርሐኒ፡ ፍና፡ ጽልመት፡ ብርሃንክሙ፡ ጽዱል፨</l>
            <l n="5">ወወልታ፡ ረድኤት፡ ይኩነኒ፡ ጊዜ፡ ፀብእ፡ ወቀትል፨</l>

          </lg>
          
          <lg type="stanza" n="14">
            
            <l n="1">ሰላም፡ እብል፡ ለአፃብኢክሙ፡ ወትረ፨</l>
            <l n="2">እንዘ፡ አስተበፅዕ፡ ለፌ፡ ዘላዕሌሆን፡ አጽፋር፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ እለ፡ ፈጸምክሙ፡ በድረ፨</l>
            <l n="4">ምስሌክሙ፡ ለተዋርሶ፡ ሰማያዊተ፡ ሀገረ፨</l>
            <l n="5">እንዘ፡ አጋእዝት፡ አንትሙ፡ እኩንክሙ፡ ገብረ፨</l>

          </lg>
          
          <lg type="stanza" n="15">
            
            <l n="1">ሰላም፡ ለገቦክሙ፡ ዘበዐራተ፡ ደም፡ ስኩብ፨</l>
            <l n="2">ወለከርሥክሙ፡ ሰላም፡ እምሀሊበ፡ አጥባት፡ ርኁብ፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ቅድመ፡ መንበሩ፡ ለአብ፨</l>
            <l n="4">አዘክሩ፡ ተገፍዖትየ፡ እምእደ፡ ነኪራን፡ ሕዝብ፨</l>
            <l n="5">ወበእንቲአየ፡ አንሶሰው፡ ውስተ፡ ሣህል፡ መርህብ፨</l>

          </lg>
          
          <lg type="stanza" n="16">
            
            <l n="1">ሰላም፡ ለልብክሙ፡ ዘይዋሄሁ፡ መንክር፨</l>
            <l n="2">ለኵልያቲክሙሂ፡ ፍቱናነ፡ ጥበብ፡ ከውር፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ሠናያነ፡ ዜና፡ ወዝክር፨</l>
            <l n="4">ብርሃነ፡ ፀሓይ፡ ይመስለኒ፡ ዘጸልመ፡ በቀትር፨</l>
            <l n="5">ሶበ፡ እዜክሮ፡ ለሞትክሙ፡ ክቡር፨</l>

          </lg>
          
          <lg type="stanza" n="17">
            
            <l n="1">ሰላም፡ ለኅሊናክሙ፡ ዘኢያእመረ፡ እከየ፨</l>
            <l n="2">ለአማዑቲክሙሂ፡ ዘበነደ፡ ሥቃይ፡ ውዕየ፨</l>
            <l n="3">ሕፃናት፡ አጽምዑ፡ ቃለ፡ ስእለትየ፨</l>
            <l n="4">እምኀይለ፡ ጸላኢ፡ ከመ፡ ኢይፍራህ፡ ልብየ፨</l>
            <l n="5">ወአመ፡ በትስቢት፡ ሮዱ፡ ጸባኢት፡ ኪያየ፨</l>

          </lg>
          
          <lg type="stanza" n="18">
            
            <l n="1">ሰላም፡ ለንዋየ፡ ውሥጥክሙ፡ መዝገበ፡ የውሃት፡ ሐዲስ፨</l>
            <l n="2">ወለኅንብርትክሙ፡ ህልው፡ ምእከለ፡ ክርሥ፨</l>
            <l n="3">መልእክተ፡ አድም፡ አቡነ፡ ዘበእንተ፡ ዋሕድ፡ ክርስቶስ፨</l>
            <l n="4">ድኅረ፡ ሰምዐ፡ ቅድመ፡ ጉባኤ፡ እምቃለ፡ ነገሥታት፡ ዘፋርስ፨</l>
            <l n="5">ኪያክሙ፡ ሕፃናት፡ አቅተለ፡ ሄሮድስ፨</l>

          </lg>
          
          <lg type="stanza" n="19">
            
            <l n="1">ሰላም፡ ለሐቌክሙ፡ ዘኢጸንዐ፡ መሌሊት፨</l>
            <l n="2">ወለአቍያጺክሙ፡ ሰላም፡ አዕማደ፡ ጽኑዕ፡ ብርት፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳ፡ ምሉኣነ፡ ጸጋ፡ ወሀብት፨</l>
            <l n="4">ዘቀደመ፡ እምኔክሙ፡ በከዊነ፡ ክቡር፡ ሰማዕት፨</l>
            <l n="5">አልቦ፡ በምድር፡ እምኵሉ፡ ፍጥረት፨</l>

          </lg>
          
          <lg type="stanza" n="20">
            
            <l n="1">ሰላም፡ ለአብራኪክሙ፡ ወለአእጋሪክሙ፡ ካዕበ፨</l>
            <l n="2">እለ፡ ኢያንሶሰዋ፡ ምዕረ፡ ዘኀጢአት፡ መርህበ፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ከመ፡ ቃለ፡ መጽሐፍ፡ ነበበ፨</l>
            <l n="4">ለሕይወትክሙ፡ ድኅረ፡ ሰኰናሃ፡ ዐተበ፨</l>
            <l n="5">አርዌ፡ ፍና፡ እከይ፡ ሄሮድስ፡ በመቅሠፍት፡ ሰከበ፨</l>

          </lg>
          
          <lg type="stanza" n="21">
            
            <l n="1">ሰላም፡ ለሰኰናክሙ፡ ድኅረ፡ ዐረፍተ፡ እግር፡ ቤት፨</l>
            <l n="2">ለመከየድክሙሂ፡ ዘኢያጸመዎ፡ ፍኖት፨</l>
            <l n="3">ሕፃናት፡ ለክሙ፡ እምነቢበ፡ ብዙኀ፡ ማሕሌት፨</l>
            <l n="4">ኢየዐርፍ፡ ቃለ፡ ዚአየ፡ በኍልቈ፡ ኵሉ፡ ዕለት፨</l>
            <l n="5">እስመ፡ አኰቴት፡ ዘስምክሙ፡ ይእቲ፡ ዕረፍት፨</l>

          </lg>
          
          <lg type="stanza" n="22">
            
            <l n="1">ሰላም፡ ለአፃብዒክሙ፡ ወለአጽፋሪሆን፡ ሰላም፨</l>
            <l n="2">እለ፡ ቅቡኣት፡ በደም፨</l>
            <l n="3">ሕፃናት፡ ፍሡሓን፡ እንዘ፡ ውስተ፡ ኵሉ፡ ዓዸም፨</l>
            <l n="4">በወርኀ፡ ልደቱ፡ ለዳግማዊ፡ አዳም፨</l>
            <l n="5">ዲበ፡ እምክሙ፡ ራሄል፡ ተስፍሐ፡ ሕማም፨</l>

          </lg>
          
          <lg type="stanza" n="23">
            
            <l n="1">ሰላም፡ ለቆምክሙ፡ ዘኢያብጽሐ፡ አምጣነ፨</l>
            <l n="2">ወለመልክእክሙ፡ ሰላም፡ ሥርግወ፡ ላህይ፡ ዘኮነ፨</l>
            <l n="3">ሕፃናት፡ ቅዱሳን፡ ዐፅፈ፡ መላእክት፡ ብርሃነ፨</l>
            <l n="4">እንዘ፡ ትትዐፀፉ፡ ወትሬስዩ፡ ክዳነ፨</l>
            <l n="5">ሐወጹ፡ በትፍሥሕት፡ ዓለመ፡ ኅዙነ፨</l>

          </lg>
          
          <lg type="stanza" n="24">
            
            <l n="1">ሰላም፡ ለፀአትክሙ፡ እምቤተ፡ ሥጋ፡ በነፍስ፨</l>
            <l n="2">ወለበድንክሙ፡ ግዱፍ፡ ውስተ፡ መርኅበ፡ ሳሌም፡ ቍድስ፨</l>
            <l n="3">ሕፃናት፡ ዕሡራን፡ ለከብካበ፡ መንግሥት፡ ሐዳስ፨</l>
            <l n="4">በአክሊለ፡ ጸጋ፡ ለዘዚአክሙ፡ ርእስ፨</l>
            <l n="5">ክልልዎ፡ ኃይላቲሁ፡ ለጥሕድ፡ ክርስቶስ፨</l>

          </lg>
          
          <lg type="stanza" n="25">
            
            <l n="1">ሰላም፡ ለግንዘትክሙ፡ በእደ፡ መላእክት፡ ኄራን፨</l>
            <l n="2">ለመቃብሪክሙሂ፡ ኢየሩሳሌም፡ መካን፨</l>
            <l n="3">ሕፃናት፡ ማሕሌተ፡ ምስለ፡ ድምፀ፡ መጥቅዕ፡ ወቀርን፨</l>
            <l n="4">ያቄርቡ፡ ለክብርክሙ፡ ካህናተ፡ ዘይብል፡ ብፅዓን፨</l>
            <l n="5">ወባረከ፡ ዓመተ፡ ጻድቃኑ፡ ንዑ፡ ንትፈሣሕ፡ ዮም፡ በበዓሎሙ፡ ለቅዱሳን፨</l>

          </lg>
          
        </div>

        <div type="textpart" xml:id="tarafa-malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለክሙ፡ ለርስተ፡ ቅዱሳን፡ ክርስቶስ፡ ወሀገረ፡ አበው፡ ጻድቃን፨</l>
            <l n="2">ተዋርሶቶ፡ በክብር፡ ሕፃናት፡ ኄራን፨</l>
            <l n="3">አድማዕክሙ፡ ቅድመ፡ ዘመን፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለክሙ፡ ወልደ፡ ዐመፃ፡ ሄሮድስ፡ መዐርገ፡ ሐራ፡ ለክሙ፨</l>
            <l n="2">እንዘ፡ ሕፃናት፡ ይመስል፡ ዘይሁበክሙ፨</l>
            <l n="3">ለሞት፡ ጸውዐክሙ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለክሙ፡ ንጽሓ፡ ዓለምክሙ፡ ይኩን፡ ሕፃናትክሙ፡ ውስተ፡ መጽሐፍ፡ ተጽሕፈ፨</l>
            <l n="2">ምግበ፡ አሐቲ፡ ዕለት፡ እስከ፡ ኀለፈ፨</l>
            <l n="3">ደምክሙ፡ ዘአንጸፍጸፈ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለክሙ፡ ሚመጠን፡ ዕለትክሙ፡ ግሩም፨</l>
            <l n="2">እስመ፡ ሕፃናት፡ አእላፍ፡ በቤተ፡ ልሔም፨</l>
            <l n="3">ጸበትክሙ፡ በማየ፡ ደም፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለክሙ፡ ቃለ፡ ደምክሙ፡ ይጽራኅ፡ ለአግብኦ፡ በቀል፡ ወፍዳ፨</l>
            <l n="2">እስከ፡ አመ፡ ትኄይስ፡ ጢሮስ፡ እምቤተ፡ ሳይዳ፨</l>
            <l n="3">ሕፃናት፡ ዘእምይሁዳ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለክሙ፡ ዜና፡ ክብርክሙ፡ እጽሕፍ፡ ሕፃናት፡ በሰሌዳ፡ ንባብ፡ ወሪቅ፨</l>
            <l n="2">ፍና፡ መርሐኒ፡ ወነገረ፡ ጽድቅ፨</l>
            <l n="3">ዮሐንስ፡ ልሳነ፡ ወርቅ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለክሙ፡ ሄሮድስ፡ እንዘ፡ ትሰክይዎ፡ ወትረ፨</l>
            <l n="2">ኵሎ፡ ዓለመ፡ ኀበ፡ ዘገብረ፨</l>
            <l n="3">ማሕፀንትክሙ፡ ዘኮነኒ፡ ፀረ፨</l>
            <l n="4">ሕፃናት፡ ስክዩ፡ ኅቡረ፨</l>

          </lg>
          
        </div>
        
      </div>
    </body>
    
