  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘተጸውዐ፡ በክብር፨</l>
            <l n="2">ወለሥዕርትከ፡ ሰላም፡ ጽዕድወ፡ ኵለንታ፡ እምፀምር፨</l>
            <l n="3">ሰረባሞን፡ ምልአኒ፡ መንፈሰ፡ ልቡና፡ ወምክር፨</l>
            <l n="4">ከመ፡ እንብብ፡ ክብረ፡ ስምከ፡ ጥዑመ፡ ዜና፡ ወዝክር፨</l>
            <l n="5">እስመ፡ ሕፁፀ፡ ልብ፡ አነ፡ ወአኮ፡ ማእምር፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለርእስከ፡ ዘኑባሬሁ፡ ተልዕለ፨</l>
            <l n="2">ወለዘውስቴቱ፡ ገጽከ፡ አርአያ፡ ፈጣሪ፡ ተሥዕለ፨</l>
            <l n="3">ሰርአባሞን፡ በስሙ፡ ለዘዲበ፡ መስቀል፡ ተሰቅለ፨</l>
            <l n="4">ሶበ፡ ቆምከ፡ ማእከለ፡ ነድ፡ እንዘ፡ ትስብክ፡ ወንጌለ፨</l>
            <l n="5">ምስለ፡ ገነውቱ፡ ኵሎሙ፡ አጵሎን፡ ተኃጕለ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለቀራንብቲከ፡ ወለዘዚአከ፡ ዐይን፨</l>
            <l n="2">ምስለ፡ ጽባሓዊ፡ ኮከብ፡ እንተ፡ የሐብር፡ በሥን፨</l>
            <l n="3">ሰረባሞን፡ ዮሴዕ፡ ዘላዕለ፡ እስራኤል፡ ካህን፨</l>
            <l n="4">ኩነኒ፡ መድኃንል፡ ገጽ፡ እምእከየ፡ ዛቲ፡ ዘመን፨</l>
            <l n="5">በሃይማኖቶሙ፡ ለአበው፡ ኄራን፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለአእዛኒከ፡ ምክረ፡ ዮሐንስ፡ ዘሰምዐ፨</l>
            <l n="2">ወለመላትሒከ፡ ሰላም፡ ዘአርአያሆን፡ ተበፅዐ፨</l>
            <l n="3">ሰረባሞን፡ ኀይላተ፡ ሶበ፡ ገበርከ፡ ርቱዐ፨</l>
            <l n="4">እምብዝኆሙ፡ ለድዉያን፡ እለ፡ በውሣጤ፡ ወአፍአ፨</l>
            <l n="5">ማኅደረ፡ እንግድዓ፡ ተሰምየት፡ ስፍሐ፡ ምድር፡ በምልዓ፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለአእናፊከ፡ ኀዋኅወ፡ ጼና፡ ምዑዝ፨</l>
            <l n="2">ወለከናፍሪከ፡ ሰላም፡ ድልዋነ፡ ንባብ፡ ሐዋዝ፨</l>
            <l n="3">ሰረባሞን፡ መጥቅዕ፡ ከመ፡ ባህለ፡ ኦሪት፡ ትእዛዝ፨</l>
            <l n="4">ትደምፅ፡ በትእምርት፡ ለጊዜ፡ መሠንይ፡ ግዒዝ፨</l>
            <l n="5">እስመ፡ ሠናየ፡ ድምፅ፡ አንተ፡ በባሕርይ፡ ወግዕዝ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለአፉከ፡ ወለአስናኒከ፡ ኵሉ፨</l>
            <l n="2">እለ፡ በበ፡ ጾታ፡ ተተክሉ፨</l>
            <l n="3">ሰረባሞን፡ ጳውሎስ፡ ለክርስቶስ፡ መጋቤ፡ ቃሉ፨</l>
            <l n="4">ጸውዐኒ፡ በስብከትከ፡ ከመ፡ አሠረከ፡ እትሉ፨</l>
            <l n="5">ወኀበ፡ ሀሎከ፡ በትፍሥሕት፡ አሀሉ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለልሳንከ፡ እንትአ፡ ሠርዓት፡ ዐቅመ፨</l>
            <l n="2">ወለነሣቲ፡ ቃልከ፡ ዘአማልክት፡ ምኅራመ፨</l>
            <l n="3">ሰረባሞን፡ ድንግል፡ ከመ፡ ነገረተከ፡ ቅድመ፨</l>
            <l n="4">ነሣእከ፡ ሀብተ፡ ጥምቀት፡ ወተሰምዮ፡ ስም፡ ዳግመ፨</l>
            <l n="5">እምእደ፡ አባ፡ አትናቴዎስ፡ ዘበሕግ፡ ተሠይመ፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ሰላም፡ ለእስትንፋስከ፡ ሕይወተ፡ ብዙኃን፡ ዘነፍሐ፨</l>
            <l n="2">ወለመዓርዒር፡ ጕርዔከ፡ እምሐሩረ፡ ሥቃይ፡ ዘሠርሐ፨</l>
            <l n="3">ሰረባሞን፡ ሕዝብከ፡ ይዌድሱከ፡ ብዙኀ፨</l>
            <l n="4">እስመ፡ አንተ፡ መምህረ፡ ጽድቅ፡ እንተ፡ ትሜህር፡ ንስሓ፨</l>
            <l n="5">ወጊዜ፡ ኀዘን፡ ትስብክ፡ ፍሥሓ፨</l>

          </lg>
          
          <lg type="stanza" n="9">
            
            <l n="1">ሰላም፡ ለክሳድከ፡ ዕጉሠ፡ ተመትሮ፡ በሰይፍ፨</l>
            <l n="2">ወሰላም፡ ካዕበ፡ ለዘዚአከ፡ መትከፍ፨</l>
            <l n="3">ሰረባሞን፡በጸጋ፡ እስመ፡ ቢጸ፡ ኀይላት፡ አእላፍ፨</l>
            <l n="4">ሥላሴ፡ ቀደስከ፡ በሥላሴ፡ ውስተ፡ ሰማያዊት፡ ምዕራፍ፨</l>
            <l n="5">ወምስለ፡ መላእክት፡ ደርገ፡ ሰረርከ፡ በክንፍ፨</l>

          </lg>
          
          <lg type="stanza" n="10">
            
            <l n="1">ሰላም፡ ለዘባንከ፡ ዘተቀሥፈ፡ ወተዘብጠ፨</l>
            <l n="2">ወለእንግድዓከ፡ ታቦት፡ ዘበወርቀ፡ ሥቃይ፡ ተለብጠ፨</l>
            <l n="3">ሰረባሞን፡ መንፈስ፡ ኀበ፡ ላዕሌከ፡ ተሠውጠ፨</l>
            <l n="4">ቅድሜከ፡ ጹገ፡ አንበሳ፡ መንገለ፡ ይዋሄ፡ ተመይጠ፨</l>
            <l n="5">እስመ፡ ከመ፡ ዳንኤል፡ አንተ፡ ዘአርዌ፡ ቀጥቀጠ፨</l>

          </lg>
          
          <lg type="stanza" n="11">
            
            <l n="1">ሰላም፡ ለሕፅንከ፡ ወለአእዳዊከ፡ በውዳሴ፨</l>
            <l n="2">ላዕለ፡ ሕዝበ፡ ጣዖት፡ ዘሰፍሐ፡ ከመ፡ በአማሌት፡ ሙሴ፨</l>
            <l n="3">ሰረባሞን፡ ቅድሜሁ፡ ዕሪና፡ ቅድስት፡ ሥላሴ፨</l>
            <l n="4">በጊዜ፡ ከሠትከ፡ እንዘ፡ ታተሉ፡ ቅዳሴ፨</l>
            <l n="5">ለሥጋ፡ መስሓቲ፡ አርዮስ፡ ረከቦ፡ ድምሳሴ፨</l>

          </lg>
          
          <lg type="stanza" n="12">
            
            <l n="1">ሰላም፡ ለመዛርዒከ፡ በቃለ፡ ትጋህ፡ እንበለ፡ ሀውክ፨</l>
            <l n="2">ዓዲ፡ ሰላም፡ ለኵርናዕከ፡ ቡሩክ፨</l>
            <l n="3">ሰረባሞን፡ መርሐኒ፡ በሰዓተ፡ ጽባሕ፡ ወሰርክ፨</l>
            <l n="4">ፍና፡ ሃይማኖት፡ ዘኢይቀርቦ፡ ተውሳክ፨</l>
            <l n="5">ከመ፡ እስከ፡ አባ፡ ቴዎናስ፡ መርሐከ፡ መልአክ፨</l>

          </lg>
          
          <lg type="stanza" n="13">
            
            <l n="1">ሰላም፡ ለእመትከ፡ ዘፍትው፡ መጠኑ፨</l>
            <l n="2">ወለእራኃቲከ፡ ፀረ፡ ዘበመንዲሉ፡ ኰነኑ፨</l>
            <l n="3">ሰረባሞን፡ በኀይል፡ ዘይትዔረየከ፡ መኑ፨</l>
            <l n="4">ስመ፡ ኀይል፡ ዘአርይም፡ ለዘሰመያ፡ ልሳኑ፨</l>
            <l n="5">ለወለተ፡ ሥጋ፡ ድንግል፡ ኰነንኮ፡ አኮኑ፨</l>

          </lg>
          
          <lg type="stanza" n="14">
            
            <l n="1">ሰላም፡ ለአፃብኢከ፡ ምስለ፡ አጽፋሪሆን፡ ዓሥር፨</l>
            <l n="2">እለ፡ አስተዋደዳ፡ ሕገ፡ ከመ፡ ድምፀ፡ ሐዋዝ፡ መዝሙር፨</l>
            <l n="3">ሐዲስ፡ ኤልሳዕ፡ ሰረባሞን፡ መምህር፨</l>
            <l n="4">ውሂበ፡ ምጽዋት፡ ለሮማንዮስ፡ ሀገር፨</l>
            <l n="5">ሶበ፡ አዘከርካ፡ ፍጹመ፡ ሐነድካ፡ በፍቅር፨</l>

          </lg>
          
          <lg type="stanza" n="15">
            
            <l n="1">ሰላም፡ ለገቦከ፡ ውስተ፡ ቤተ፡ ሞቅሕ፡ ዘሰከበ፨</l>
            <l n="2">ወለከርሥከ፡ ሰላም፡ እምኅብስተ፡ ዓለም፡ ዘርኅበ፨</l>
            <l n="3">ሰረባሞን፡ ለምኵራብ፡ ዘበምድረ፡ ሰቢን፡ ተረክበ፨</l>
            <l n="4">ጳውሎስ፡ ከመ፡ አንኀለ፡ ዘበአቴና፡ ምኵራበ፨</l>
            <l n="5">አፍጠንከ፡ አንኅሎቶ፡ ወአድኀንከ፡ ሕዝበ፨</l>

          </lg>
          
          <lg type="stanza" n="16">
            
            <l n="1">ሰላም፡ ለልብከ፡ በልበ፡ አንበሳ፡ ዘተመስለ፨</l>
            <l n="2">ወለኵልያቲከ፡ ጥበብ፡ ዘእምኔሆን፡ ፈልፈለ፨</l>
            <l n="3">ሰረባሞን፡ ጴጥሮስ፡ ከመ፡ ውስተ፡ መጽሐፍ፡ ተብህለ፨</l>
            <l n="4">እምጽላሎትከ፡ ገቢረ፡ ተአምር፡ ዘክህለ፨</l>
            <l n="5">ሕሙማነ፡ ሥጋ፡ ወነፍስ፡ ተጸገው፡ ሣህለ፨</l>

          </lg>
          
          <lg type="stanza" n="17">
            
            <l n="1">ሰላም፡ ለኅሊናከ፡ ዘይኄሊ፡ ምክረ፨</l>
            <l n="2">ወለአማዑቲከ፡ ሰላም፡ ዘበፍቅረ፡ ወልድ፡ ተመትረ፨</l>
            <l n="3">ሰረባሞን፡ አነክር፡ በኀይለ፡ ጸሎትከ፡ ወትረ፨</l>
            <l n="4">ለነደ፡ እሳት፡ ዘተለዐለ፡ መንክረ፨</l>
            <l n="5">እስመ፡ ከመ፡ ማይ፡ ወጠል፡ ረሰዮ፡ ቈሪረ፨</l>

          </lg>
          
          <lg type="stanza" n="18">
            
            <l n="1">ሰላም፡ ለንዋየ፡ ውስጥከ፡ መና፡ መሶበ፡ ወርቅ፡ ከርሠ፨</l>
            <l n="2">ወለኅንብርትከ፡ ሰላም፡ ዘአርአያሁ፡ ውዱስ፨</l>
            <l n="3">አልብየ፡ ለብእሴ፡ ሥጋ፡ ግሡሥ፨</l>
            <l n="4">እምእዴከ፡ ዘእንበሌሃ፡ ለረድኤተ፡ ሥጋ፡ ወነፍስ፨</l>
            <l n="5">ፈቃድ፡ ካልእ፡ ወካልእ፡ ማኅሠሥ፨</l>

          </lg>
          
          <lg type="stanza" n="19">
            
            <l n="1">ሰላም፡ ለሐቌከ፡ ዘቀነተ፡ ኀብለ፡ ጸጋ፨</l>
            <l n="2">ወለአቍያጺከ፡ ሰላም፡ እለ፡ ያጸንዐ፡ ድካመ፡ ሥጋ፨</l>
            <l n="3">ሰረባሞን፡ ዘረውከ፡ መምለክያነ፡ ዕፅ፡ እንግልጋ፨</l>
            <l n="4">እስመ፡ አንተ፡ ምሉአ፡ ኀይል፡ እምድካመ፡ ካልእ፡ ንትጋ፨</l>
            <l n="5">ጊዜ፡ ለኀላፊት፡ ዓለም፡ ኢቆምከ፡ በሕጋ፨</l>

          </lg>
          
          <lg type="stanza" n="20">
            
            <l n="1">ሰላም፡ ለአብራኪከ፡ ካህናተ፡ መቅደስ፡ አስተብርኮ፨</l>
            <l n="2">ወለእግርከ፡ ዘቆመ፡ ውስተ፡ ዐውደ፡ ሥቃይ፡ በኢተሀውኮ፨</l>
            <l n="3">ሰረባሞን፡ ሠናየ፡ ለእግዚአብሔር፡ ዘትትለአኮ፨</l>
            <l n="4">ትሑተ፡ ልብ፡ ወየዋሃ፡ ዘኢትትሜንን፡ አምልኮ፨</l>
            <l n="5">መሥዋዕተ፡ መንፈስከ፡ ሠምረት፡ ደመ፡ ላህም፡ አኮ፨</l>

          </lg>
          
          <lg type="stanza" n="21">
            
            <l n="1">ሰላም፡ ለሰኰናከ፡ ዘበነደ፡ እሳት፡ ኢሐመ፨</l>
            <l n="2">ወለመከየድከ፡ ህየ፡ ዘጻማ፡ ገድሉ፡ ፈጸመ፨</l>
            <l n="3">ሰረባሞን፡ ሰማዕት፡ ሐመረ፡ ሥቃይከ፡ ቅድመ፨</l>
            <l n="4">ሐዊረ፡ ሶበ፡ ኀደገ፡ ወበጽንፈ፡ ባሕር፡ ቆመ፨</l>
            <l n="5">ዘአንቀልቅሎቶ፡ ኢክህለ፡ ሀቤ፡ ፻ተደመ፨</l>

          </lg>
          
          <lg type="stanza" n="22">
            
            <l n="1">ሰላም፡ ለአፃብኢከ፡ አዕፁቀ፡ መከየድ፡ አርዝ፨</l>
            <l n="2">ወለአጽፋሪከ፡ ሰላም፡ ኅቡራነ፡ መልክእ፡ ወግዕዝ፨</l>
            <l n="3">ሰረባሞን፡ ሕያው፡ ኦተ፡ ኀጢአት፡ ግዑዝ፨</l>
            <l n="4">ቅድሜከ፡ ይኩን፡ ጌጋይየ፡ በሥልጣንከ፡ ዐዚዝ፨</l>
            <l n="5">ከመ፡ ማዕበል፡ ዘኀለፈ፡ ወነጽፈ፡ ውሒዝ፨</l>

          </lg>
          
          <lg type="stanza" n="23">
            
            <l n="1">ሰላም፡ ለቆምከ፡ ብጹሐ፡ አምጣን፡ ቆም፨</l>
            <l n="2">ዓዲ፡ ዳግመ፡ ለመልክእከ፡ ሰላም፨</l>
            <l n="3">ሰረባሞን፡ መዋዒ፡ ቀርነ፡ ቤተ፡ ዳዊት፡ ሥዩም፨</l>
            <l n="4">ብከ፡ ንወግዖሙ፡ ሕዝበ፡ ሕግከ፡ ፍጹም፨</l>
            <l n="5">ለእለ፡ ኮኑነ፡ ፀረ፡ ኀበ፡ ይምን፡ ወፅግም፨</l>

          </lg>
          
          <lg type="stanza" n="24">
            
            <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ድኅረ፡ ምግበ፡ ሥቃይ፡ ዕጹብ፨</l>
            <l n="2">ወለበድነ፡ ሥጋከ፡ ግዱፍ፡ ውስተ፡ ፍና፡ ገዳም፡ ርኂብ፨</l>
            <l n="3">ሰረባሞን፡ በቋዒ፡ ወሠናይ፡ ሥርዓት፡ አብ፨</l>
            <l n="4">እፎኑ፡ ኀደገ፡ መርዔተከ፡ ማእከለ፡ ተኵላ፡ ርኁብ፨</l>
            <l n="5">እንዘ፡ ይብሉ፡ በሞትከ፡ ይበክዩ፡ ሕዝብ፨</l>

          </lg>
          
          <lg type="stanza" n="25">
            
            <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በልብሰ፡ ስኂን፡ ወከርቤ፨</l>
            <l n="2">ወለመቃብሪከ፡ ሰላም፡ በስብሐት፡ ወይባቤ፨</l>
            <l n="3">ሰረባሞን፡ ሰማዕት፡ ሐውጸኒ፡ አመ፡ ምንዳቤ፨</l>
            <l n="4">ወኩነኒ፡ ቅድመ፡ ፀርየ፡ በረድኤትከ፡ ዐቃቤ፨</l>
            <l n="5">በተዘክሮ፡ ዘለክብርከ፡ ነበብኩ፡ ወእቤ፨</l>

          </lg>
          
        </div>

        <div type="textpart" xml:id="tarafa-malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለከ፡ ሰረባሞን፡ በሕግ፡ አምጣነ፡ አንተ፡ ምእመን፨</l>
            <l n="2">እምአፈ፡ አምላክ፡ ሰማዕከ፡ ቅድመ፡ ጉቡኣን፨</l>
            <l n="3">ዘኤርምያስ፡ ቃለ፡ ብፅዓን፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለከ፡ ጸሎተ፡ ፫ደቂቅ፡ ሶበ፡ ማእከለ፡ ነድ፡ ጸለይከ፨</l>
            <l n="2">ሰረባሞን፡ ሰማዕት፡ በሃይማኖትከ፨</l>
            <l n="3">ዝርዋነ፡ አስተጋባእከ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለከ፡ ዜና፡ አስጢፋኖስ፡ ሥጋከ፡ ቀዳሜ፡ ኵሉ፡ ሰማዕት፨</l>
            <l n="2">እስመ፡ ሰረባሞን፡ ሰማዕከ፡ እምቃለ፡ ቀደምት፨</l>
            <l n="3">ተጋደልከ፡ በትዕግሥት፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለከ፡ እምቃለ፡ ማርያም፡ ምክረ፡ ድኅረ፡ ሰማዕከ፡ በሕልም፨</l>
            <l n="2">ከመ፡ ሰረባሞን፡ ትንሣእ፡ ሥርዓተ፡ ሰላም፨</l>
            <l n="3">አንሶሰውከ፡ ውስተ፡ ገዳም፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለከ፡ ለአርያኖስ፡ መስፍን፡ ሰረባሞን፡ አቡየ፡</l>
            <l n="2">ከዊነ፡ ሰማዕት፡ ቃልከ፡ ከመ፡ ተነበየ፨</l>
            <l n="3">ተነበይ፡ በእንቲአየ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለከ፡ ተፍጻሜተ፡ ሰማዕት፡ ጴጥሮስ፡ ሰረባሞን፡ ከመ፡ ጸውዐ፡ ኪያከ፨</l>
            <l n="2">ፍካሬ፡ መጻሕፍት፡ ይስማዕ፡ እምነ፡ ቃልከ፨</l>
            <l n="3">ጸውዐኒ፡ ውስተ፡ ክብርከ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለከ፡ እማዕምቀ፡ ልብየ፡ አባ፡ ጸዋዕኩከ፡ ጸውዖ፨</l>
            <l n="2">ባሕቱ፡ ኩነኒ፡ በተራድኦ፨</l>
            <l n="3">ሰረባሞን፡ ኀይለ፡ ጊዜ፡ ተገፍዖ፨</l>
            <l n="4">ወቃልየ፡ ስምዐኒ፡ እግዚኦ፨</l>

          </lg>
          
        </div>
        
      </div>
    </body>
    
