  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ መአድመ፡ ስም፡ ወዜና፨</l>
            <l n="2">እንጦንዮስ፡ ሙሴ፡ ሕፃነ፡ እንበረም፡ ንጽሕና፨</l>
            <l n="3">ለእስራኤላዊ፡ ወልድከ፡ ማዕከለ፡ ዓለም፡ ሲና፨</l>
            <l n="4">በጊዜ፡ ረሐብ፡ ሰዓተ፡ ግሩም፡ ሙስና፨</l>
            <l n="5">ሴሰየኒ፡ ወትረ፡ ረድኤተከ፡ መና፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለስዕርትከ፡ ዕረፍተ፡ ጸጋ፡ ቅቡዕ፨</l>
            <l n="2">ወለርዕስከ፡ ሰላም፡ ክሉለ፡ ጌራ፡ ቆብዕ፨</l>
            <l n="3">ገብሩ፡ በጸጋ፡ ለዘገብረከ፡ እግዚእ፨</l>
            <l n="4">ወአንተ፡ አምሳሊሁ፡ በከዊነ፡ ሥጋ፡ ወሰብእ፨</l>
            <l n="5">እንጦንዮስ፡ መምህር፡ ወቡሩክ፡ ረድእ፨</l>

          </lg>
          
        </div>

        
        
      </div>
