  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ እንተ፡ ጸሐፎ፡ መሳፍነ፡ ሮም፨</l>
            <l n="2">ወለሥዕርተ፡ ርእስከ፡ ሲሩይ፡ በርጥበተ፡ ቅይሕ፡ ደም፨</l>
            <l n="3">ኢየሱስ፡ ክርስቶስ፡ አርአያ፡ ገጸ፡ አብ፡ አዳም፨</l>
            <l n="4">ተወሐደ፡ በላዕሌከ፡ ተዋሕዶተ፡ አካል፡ ወእም፨</l>
            <l n="5">መለኮት፡ ትማልሞ፡ ወትስብእት፡ ዮም፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ሰላም፡ ለዝባንከ፡ በእደ፡ ጲላጦስ፡ ሐማሚ፨</l>
            <l n="2">ወለእንግድኣከ፡ ሰቱፍ፡ እምጻማ፡ መስቀል፡ ቀዋሚ፨</l>
            <l n="3">ኢየሱስ፡ ክርስቶስ፡ ሃይማኖተ፡ ጳውሎስ፡ ዘርአ፡ ብንያሚ፨</l>
            <l n="4">እግዚኦ፡ አድኅነኒ፡ እማእበለ፡ ባሕር፡ መሰጣሚ፨</l>
            <l n="5">ከመ፡ አድኅንኮ፡ ለጴጥሮስ፡ ቀዳሚ፨</l>

          </lg>
          
          <lg type="stanza" n="18">
            
            <l n="1">ሰላም፡ ለዕርገትከ፡ ድኅረ፡ ወረድከ፡ እምራማ፨</l>
            <l n="2">አእጻዳተ፡ ቆላት፡ ትሰፈር፡ ወከመ፡ ትትካፈል፡ ብዙኅ፡ ዕቂማ፨</l>
            <l n="3">ኢየሱስ፡ ክርስቶስ፡ ንጉሠ፡ ነገሥታት፡ ፌማ፨</l>
            <l n="4">እስምዐኒ፡ ቃለ፡ ትፍሕት፡ አመ፡ ትመጽእ፡ በግርማ፨</l>
            <l n="5">እሴተ፡ ማሕሌትየ፡ ዛቲዘእዴር፡ አቅማ፨</l>

          </lg>
          
          <lg type="stanza" n="19">
            
            <l n="1">ሰላም፡ ለፈንዎትከ፡ በዕለተ፡ እሑድ፡ እምሱባኤ፨</l>
            <l n="2">ጰራቅሊጦስሃ፡ ኀበ፡ ማኅድሩ፡ ሰብአ፡ ዝንጋዔ፨</l>
            <l n="3">ኢየሱስ፡ ክርስቶስ፡ ውስተ፡ ቤተ፡ መርአከ፡ አመ፡ ጽዋዔ፨</l>
            <l n="4">ከመ፡ እባእ፡ በምሕረትከ፡ መ.ለ፡ ንጹሓን፡ ጉባኤ፨</l>
            <l n="5">እንበለ፡ ምግባር፡ ገብርከ፡ እሴፎ፡ ትንሣኤ፨</l>

          </lg>
          
          <lg type="stanza" n="20">
            
            <l n="1">ሰላም፡ ለመጽአትከ፡ በነደ፡ እሳት፡ እምአርያም፨</l>
            <l n="2">መንግሥተ፡ ሰማያት___ቶ፡ ዘተማልም፡ ወዮም፨</l>
            <l n="3">እብ______ እምጽንአ ኵነኔ፡ ግሩም፨</l>
            <l n="4">________ አብዝኁ፡ በዛቲ፡ ______</l>
            <l n="5"> </l>

          </lg>
          
        </div>

        
        
      </div>
