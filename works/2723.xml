  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">መሠረተ፡ ፈቃድ፡ አስተናይፍኩ፡ ከመ፡ ጠቢብ፡ ሊቀ፡ ፀረብት።</l>
            <l n="2">ዲበ፡ ኰኵሐ፡ ስምከ፡ እሕንጽ፡ ማኅፈደ፡ ክቡር፡ ማኅሌት።</l>
            <l n="3">ጲላጦስ፡ መስግን፡ ዘኢየሩሳሌም፡ ቅድስት፨</l>
            <l n="4">ባሕቱ፡ ካልእ፡ ዘእምኀቤከ፡ ረድኤት፨</l>
            <l n="5">ያስተፋጥን፡ ሐድሶታ፡ ለዛቲ፡ ሕንፀት፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ በጽላተ፡ ሰማይ፡ ዘተጽሕፈ፨</l>
            <l n="2">ወለድማኅከ፡ ምሉእ፡ ጸጋ፡ ሌሊተ፡ ገድል፡ ነፍኒፈ፨</l>
            <l n="3">ጲላጦስ፡ ክብርከ፡ እምወሰነ፡ ክብር፡ ኃለፈ፨</l>
            <l n="4">ለክርስቶስ፡ ፍዳ፡ ሥቃዩ፡ እስመ፡ ሥጋከ፡ ተወክፈ፨</l>
            <l n="5">ሥቃየ፡ ንጉሥ፡ ጢባርዮስ፡ ዘይኴንን፡ እልፈ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለርእስከ፡ ከመ፡ ርእሰ፡ ክርስቶስ፡ ዘተኰርዓ፨</l>
            <l n="2">ወእመንፈስ፡ ቅዱስ፡ ገጸከ፡ ቅብዓ፡ ስነ፡ ሞገስ፡ ተቀብዓ፨</l>
            <l n="3">ጲላጦስ፡ አፍአዊ፡ እስመ፡ ፍና፡ ሀብትከ፡ ረትዓ፨</l>
            <l n="4">ኪያከ፡ ኀበ፡ ከብካብ፡ ከመ፡ በዓለ፡ ቤት፡ ፀውዓ፨</l>
            <l n="5">አስተሳትፈኒ፡ በጸውኦ፡ ከብካበ፡ ወመርዓ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለቀራንብቲከ፡ አጽናፈ፡ ዓይንከ፡ ባሕር፨</l>
            <l n="2">ዘኆፃ፡ ዕመቁ፡ ነጽሮ፡ መጽሔተ፡ ኅቡአ፡ ምሥጢር፨</l>
            <l n="3">ጲላጦስ፡ አርአይከ፡ ለአምላከ፡ ሰማይ፡ ወምድር፨</l>
            <l n="4">ምግባረከ፡ ወየውሃት፡ ስነ፡ ሃይማኖት፡ ወፍቅር፨</l>
            <l n="5">አምጣነ፡ ጠቢብ፡ አንተ፡ ወብእሲ፡ ምኩር፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለአእዛኒከ፡ እለ፡ አጽምአ፡ ሐተታ፨</l>
            <l n="2">ፍዳ፡ ሐተትኮ፡ ለክርስቶስ፡ በዓውደ፡ መስቀል፡ ዘጎልጎታ፨</l>
            <l n="3">ጲላጦስ፡ ወልድከ፡ ኢይኩን፡ እጓለ፡ ማውታ፨</l>
            <l n="4">ምስለ፡ ቃል፡ ዘሐወፀከ፡ ለቤተ፡ ሞቅሕ፡ ውስቴታ፨</l>
            <l n="5">ሐውፀኒ፡ ለለጊዜ፡ በብዙኅ፡ ፆታ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለመላትሒከ፡ እለ፡ ተጸፍዓ፡ እምአይሁድ፨</l>
            <l n="2">ወዓልተ፡ ቀያፋ፡ ወሐና፡ ከመ፡ ለአምላክከ፡ ወልድ፨</l>
            <l n="3">ጲላጦስ፡ ከማከ፡ እምድቀትየ፡ ለእብድ፨</l>
            <l n="4">አንሥአኒ፡ እቁም፡ እጊኦ፡ ውስተ፡ ባህለ፡ ቃልከ፡ ዓውድ፨</l>
            <l n="5">መሬት፡ አነ፡ ወአነ፡ ሐመድ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለአእናፊከ፡ ማእከለ፡ አዕይንት፡ እለ፡ ተፈጥራ፨</l>
            <l n="2">ወለከናፍሪከ፡ ሰላም፡ በቃለ፡ ስብሐት፡ ድምፀ፡ እንዚራ፨</l>
            <l n="3">ጲላጦስ፡ ቅሡፍ፡ እምወዓልተ፡ ሄሮድስ፡ ሐራ፨</l>
            <l n="4">ኢያንከርከ፡ ከመ፡ ሕያው፡ ዘበጽሐተከ፡ መከራ፨</l>
            <l n="5">እስመ፡ ለመንግሥት፡ ሰማያዊት፡ ቀተለከ፡ ፍቅራ፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ሰላም፡ ለአፉከ፡ ምስለ፡ አፈ፡ ክርስቶስ፡ ዘተናበበ፨</l>
            <l n="2">ወለአስናኒከ፡ ሎሙ፡ ዘስነ፡ ፅዕዳዌ፡ ተውህበ፨</l>
            <l n="3">ጲላጦስ፡ በክርስቶስ፡ እምቅድመ፡ ታጥሪ፡ ጥበበ፨</l>
            <l n="4">ተፋቀርከ፡ ምስለ፡ ሄሮድስ፡ እንዘ፡ ታስተፃንዕ፡ ሕዝበ፨</l>
            <l n="5">ወምስለ፡ ሄሮድስ፡ በክርስቶስ፡ ተበእስከ፡ ካዕበ፨</l>

          </lg>
          
          <lg type="stanza" n="9">
            
            <l n="1">ሰላም፡ ለልሳንከ፡ ወለቃልከ፡ ዳግመ፨</l>
            <l n="2">አምጣነ፡ መፍትው፡ ጲላጦስ፡ ከመ፡ ትትወከፍ፡ ሰላመ፨</l>
            <l n="3">መፍቀሪተ፡ አምላክ፡ አብሮቅላ፡ ሶበ፡ አይድዓተከ፡ ሕልመ፨</l>
            <l n="4">ፍትሐ፡ ሞት፡ ኢትፍታሕ፡ ላዕሌሁ፡ ለዘፈጠረ፡ ዓለመ፨</l>
            <l n="5">እምነ፡ ደሙ፡ ነጻሕከ፡ ወከዓውከ፡ ደመ፨</l>

          </lg>
          
          <lg type="stanza" n="10">
            
            <l n="1">ሰላም፡ ለእስትንፋስከ፡ ዘነፍሐ፡ ሃይማኖተ፨</l>
            <l n="2">ወለመዓርዒር፡ ጕርዔከ፡ ዘበጣዕመ፡ ወንጌል፡ ተከሥተ፨</l>
            <l n="3">ማኅበረ፡ አይሁድ፡ እንዘ፡ መልአኮሙ፡ አንተ፨</l>
            <l n="4">እፎኑመ፡ ቀሠፉከ፡ ወዓሠሩከ፡ ድኅሪተ፨</l>
            <l n="5">እስከ፡ ሰቀሉከ፡ ከመ፡ ወልድ፡ በመስቀል፡ ዘሞተ፨</l>

          </lg>
          
          <lg type="stanza" n="11">
            
            <l n="1">ሰላም፡ ለክሳድከ፡ ጲላጦስ፡ ሐራዊ፨</l>
            <l n="2">ወመኰንን፡ ሮማዊ፨</l>
            <l n="3">በአክሊል፡ ዘሦክ፡ ከመ፡ ሊቅከ፡ ናዝራዊ፨</l>
            <l n="4">ሶበ፡ ለከ፡ አሕመሙከ፡ ትውልደ፡ ስምዖን፡ ወሌዊ፨</l>
            <l n="5">ኢተፃብዓከ፡ ሕሊና፡ ምድራዊ፨</l>

          </lg>
          
          <lg type="stanza" n="12">
            
            <l n="1">ሰላ፡ ለመትከፍትከ፡ ዘጾረ፡ መስቀለ፨</l>
            <l n="2">ወለዘባንከ፡ ሰላም፡ በመቅሠፍተ፡ አይሁድ፡ ዘቈስለ፨</l>
            <l n="3">ጲላጦስ፡ በስሙ፡ እስመ፡ አሠነይከ፡ ገድለ፨</l>
            <l n="4">አምላክ፡ ዘቀሠፍኮ፡ እንዘ፡ የኃድግ፡ በቀለ፨</l>
            <l n="5">አውረደ፡ ለከ፡ እምሰማይ፡ አክሊለ፨</l>

          </lg>
          
          <lg type="stanza" n="13">
            
            <l n="1">ሰላም፡ ለእንግድዓከ፡ መዝገበ፡ አእምሮ፡ ክቡድ፨</l>
            <l n="2">ወለሕፅንከ፡ ሰላም፡ ዘወይነ፡ ሥቃይ፡ ምክያድ፨</l>
            <l n="3">ጲላጦስ፡ ለሄሮድስ፡ በዘ፡ እምአርያም፡ ነድ፨</l>
            <l n="4">ኰነንዎ፡ በእንቲአከ፡ መላእክተ፡ ዋሕድ፡ ወልድ፨</l>
            <l n="5">ወማኅደራቲሁ፡ ዳግመ፡ አውዓዩ፡ አይሁድ፨</l>

          </lg>
          
          <lg type="stanza" n="14">
            
            <l n="1">ሰላም፡ ለአእዳዊከ፡ እለ፡ ፅዑራን፡ በሰናስል፨</l>
            <l n="2">ወለማዝርዒከ፡ ሰላም፡ ምስለ፡ ኵርናዕከ፡ እብል፨</l>
            <l n="3">ለዘአርማትያስ፡ ዮሴፍ፡ ወኒቆዲሞስ፡ ባዕል፨</l>
            <l n="4">ጊዜ፡ ሰርክ፡ ዘሰአሉከ፡ በድነ፡ ሥጋ፡ ክርስቶስ፡ ቃል፨</l>
            <l n="5">ተሳተፍከ፡ ምስሌሆሙ፡ ጲላጦስ፡ በገድል፨</l>

          </lg>
          
          <lg type="stanza" n="15">
            
            <l n="1">ሰላም፡ ለእመትከ፡ መሥፈርተ፡ ምልዓት፡ እምንትጋ፨</l>
            <l n="2">ወለእራኅከ፡ ስፉሕ፡ ለነሢአ፡ ሞገስ፡ ወጸጋ፨</l>
            <l n="3">ጲላጦስ፡ ለክርስቶስ፡ መቃብሪሁ፡ በሥጋ፨</l>
            <l n="4">ለቄሳር፡ ሶበ፡ አንሥኦ፡ አብራከ፡ በጥሮንዮስ፡ ዓርጋ፨</l>
            <l n="5">ውስተ፡ ደብረ፡ ስግደት፡ ለክብርከ፡ ቅድመ፡ ሕዝብ፡ እንግልጋ፨</l>

          </lg>
          
          <lg type="stanza" n="16">
            
            <l n="1">ሰላም፡ ለአፃብዒከ፡ በሰሌዳ፡ መስቀል፡ እለ፡ ጸሐፉ፨</l>
            <l n="2">መንግሥተ፡ ኢየሱስ፡ ዘሞተ፡ በምክረ፡ ካህን፡ ቀያፋ፨</l>
            <l n="3">ጲላጦስ፡ ኢትቁም፡ ከመ፡ ሕዝበ፡ አይሁድ፡ ዓውደ፡ ዘለፋ፨</l>
            <l n="4">ተባየፅከ፡ በንስሐከ፡ ምስለ፡ ዘነስሓ፡ ኬፋ፨</l>
            <l n="5">ወተስፋ፡ ኬፋ፡ መንፍሥት፡ ኮነተከ፡ ተስፋ፨</l>

          </lg>
          
          <lg type="stanza" n="17">
            
            <l n="1">ሰላም፡ ለአጽፋረ፡ እዴከ፡ እለ፡ ንቡራት፡ በተልዕሎ፨</l>
            <l n="2">መልዕልተ፡ አፃብዕ፡ ዓሥር፡ እንዘ፡ ንቡራት፡ በተመስሎ፨</l>
            <l n="3">ጲላጦስ፡ ቆምከ፡ ቅድመ፡ ጢባርዮስ፡ ምስለ፡ ተፅዕሎ፨</l>
            <l n="4">ቅድሜከ፡ ተውላጠ፡ ቆመ፡ ዘያቀም፡ ኵሎ፨</l>
            <l n="5">እንዘ፡ ሕዝበ፡ አይሁድ፡ ይብሉከ፡ ስቅሎ፡ ስቅሎ፨</l>

          </lg>
          
          <lg type="stanza" n="18">
            
            <l n="1">ሰላም፡ ለገቦከ፡ ኲናተ፡ መከራ፡ ዘረገዞ፨</l>
            <l n="2">ወለከርሥከ፡ ድኅረዝ፡ ኅብስተ፡ ዓለም፡ ዘኢሐወዞ፨</l>
            <l n="3">መንክረ፡ ሥቃያት፡ ጲላጦስ፡ እምሠራዊተ፡ ሀውክ፡ ወተጋዕዞ፨</l>
            <l n="4">አሰስል፡ በሕማምከ፡ ለሕሊናየ፡ ትካ፨</l>
            <l n="5">ወኃዘነ፡ ልብየ፡ በመንክር፡ ናዝዞ፨</l>

          </lg>
          
          <lg type="stanza" n="19">
            
            <l n="1">ሰላም፡ ለልብከ፡ ምሉአ፡ ሠናይ፡ ተፋቅሮ፨</l>
            <l n="2">ወለኵልያቲከ፡ ሰላም፡ አፍላገ፡ ማይ፡ አእምሮ፨</l>
            <l n="3">ጲላጦስ፡ ተለውከ፡ ለንጉሠ፡ መስቀል፡ ዓሠሮ፨</l>
            <l n="4">ይሁዳሰ፡ ዘኢነሥሓ፡ ወኢያእመረ፡ ክብሮ፨</l>
            <l n="5">ለሐዋርያ፡ ማትያስ፡ ኃደገ፡ ብሔሮ፨</l>

          </lg>
          
          <lg type="stanza" n="20">
            
            <l n="1">ሰላም፡ ለሕሊናከ፡ ሐልዮተ፡ አምላክ፡ ዘአፍጠነ፨</l>
            <l n="2">ወለአማዑቲከ፡ ሐፂን፡ በእሳተ፡ ፍቅሩ፡ ዘርስነ፨</l>
            <l n="3">ጲላጦስ፡ ለብርባን፡ እንዘ፡ ታሐይዎ፡ እሙነ፨</l>
            <l n="4">ለክርስቶስ፡ ሶበ፡ ቀተልኮ፡ ፍትሐ፡ ዚአከ፡ ግዕዝነ፨</l>
            <l n="5">ወሶበ፡ ቀተልኮ፡ ለበርባን፡ ፍትሐከ፡ ወደስነ፨</l>

          </lg>
          
          <lg type="stanza" n="21">
            
            <l n="1">ሰላም፡ ለንዋየ፡ ውሥጥከ፡ አእምሮ፡ ወንጌል፡ ሥርዓት፨</l>
            <l n="2">ወለኅንብርትከ፡ ሰላም፡ ቀመረ፡ ስፍሐ፡ ከርሥ፡ ቤት፨</l>
            <l n="3">ከመ፡ አትለውካ፡ ጲላጦስ፡ እመንገለ፡ ጸጋ፡ ወገብት፨</l>
            <l n="4">መሀረኒ፡ በጕጕዓ፡ ከመ፡ ባህለ፡ ኬፋ፡ ስብከት፨</l>
            <l n="5">ድኅረ፡ ሃይማኖት፡ አትልዎታ፡ ለምግባር፡ ሠናይት፨</l>

          </lg>
          
          <lg type="stanza" n="22">
            
            <l n="1">ሰላም፡ ለሐቌከ፡ ከመ፡ ሐቌ፡ ክርስቶስ፡ ቅኑተ፡ ላንጽ፨</l>
            <l n="2">ወለአቍያጺከ፡ ሰላም፡ አዕማደ፡ ሥጋ፡ ሕኑፅ፨</l>
            <l n="3">ጲላጦስ፡ ኤልሳዕ፡ መትልወ፡ ኤልያስ፡ ቢጽ፨</l>
            <l n="4">ለንአማን፡ ፍቁርከ፡ በማየ፡ ንስሐ፡ ተግሣጽ፨</l>
            <l n="5">አንጽሐኒ፡ እግዚእየ፡ እምጌጋይ፡ ለምጽ፨</l>

          </lg>
          
          <lg type="stanza" n="23">
            
            <l n="1">ሰላም፡ ለአብራኪከ፡ ንዋያተ፡ ስግደት፡ አብራክ፨</l>
            <l n="2">ወለእግርከ፡ ዘቆመ፡ ቅድመ፡ ዘአቀአምኮ፡ አምላክ፨</l>
            <l n="3">ውስተ፡ ቤተ፡ ሞቅሕ፡ ጲላጦስ፡ በትእዛዘ፡ ክርስቶስ፡ ቡሩክ፨</l>
            <l n="4">ከመ፡ ዓቀበከ፡ ኃይለ፡ ገብርኤል፡ መልአክ፨</l>
            <l n="5">ዕቀበኒ፡ እምጸላኢ፡ በጽባሕ፡ ወሰርክ፨</l>

          </lg>
          
          <lg type="stanza" n="24">
            
            <l n="1">ሰላም፡ ለሰኰናከ፡ መንክረ፡ ሩጸት፡ እምአውሎ፨</l>
            <l n="2">ወለመከየድከ፡ ሰላም፡ ዘአጥብዓ፡ ለተጋድሎ፨</l>
            <l n="3">ከመ፡ ጲላጦስ፡ ኪያከ፡ እስመ፡ ኢነጸረ፡ በተበቅሎ፨</l>
            <l n="4">አውሥኦከ፡ ቃለ፡ ፈጣሪ፡ ከመ፡ ቃልከ፡ ይቤሎ፨</l>
            <l n="5">አውሥአኒ፡ ጊዜ፡ ኀቤከ፡ አበጽሕ፡ ተስእሎ፨</l>

          </lg>
          
          <lg type="stanza" n="25">
            
            <l n="1">ሰላም፡ ለአፃብዒከ፡ አዕፁቀ፡ እግርከ፡ አርዝ፨</l>
            <l n="2">ለአጽፋረ፡ እግርከኒ፡ ሠናያነ፡ አምሳል፡ ወግዕዝ፨</l>
            <l n="3">ጲላጦስ፡ ትስብክ፡ መንክራተ፡ ክርስቶስ፡ አዚዝ፨</l>
            <l n="4">እምድረ፡ ይሁዳ፡ ዓፀደ፡ ትንቢት፡ ሐዋዝ፨</l>
            <l n="5">ተጸዋዕከ፡ ውስተ፡ ሮሜ፡ በመንክር፡ ትእዛዝ፨</l>

          </lg>
          
          <lg type="stanza" n="26">
            
            <l n="1">ሰላም፡ ለቆምከ፡ ዘዓቅመ፡ መጠኑ፡ ዓቅመ፡ አዳም፨</l>
            <l n="2">ወለለ፩፩ መላክዒከ፡ ሰላም፨</l>
            <l n="3">ጲላጦስ፡ ሰማዕት፡ በምድረ፡ ይሁዳ፡ ወሮም፨</l>
            <l n="4">እስመ፡ ተከለልከ፡ በአክሊለ፡ ጸጋ፡ ፍጹም፨</l>
            <l n="5">ብፅዓን፡ ለከ፡ እምኵሉ፡ ዓለም፨</l>

          </lg>
          
          <lg type="stanza" n="27">
            
            <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ እምድኅረ፡ መስቀል፡ በሰይፍ፨</l>
            <l n="2">ወለበድነ፡ ሥጋከ፡ ሰላም፡ ዘዕበየ፡ ክብሩ፡ ትሩፍ፨</l>
            <l n="3">ጲላጦስ፡ ቢጾሙ፡ ለማኅበረ፡ በኵር፡ አእላፍ፨</l>
            <l n="4">ለመጽሐፍ፡ ክብረ፡ ዚአከ፡ ሠናየ፡ ፍጻሬ፡ መጽሐፍ፨</l>
            <l n="5">እምአንብቦቱ፡ ኢያረምም፡ አፍ፨</l>

          </lg>
          
          <lg type="stanza" n="28">
            
            <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በእደ፡ ሰይለቡስ፡ ሊቀ፡ ገዛዕት፨</l>
            <l n="2">ወለመቃብሪከ፡ ሰላም፡ መቃብረ፡ ክርስቶስ፡ እምርት፨</l>
            <l n="3">ጲላጦስ፡ ነጋሢ፡ ተወካፌ፡ መስቀል፡ ፀባሕት፨</l>
            <l n="4">ነጐድጓድ፡ ማኅሌትከ፡ አመ፡ ወርኃ፡ በዓል፡ ክረምት፨</l>
            <l n="5">እምሰማየ፡ ልሳን፡ ተሰምዓ፡ ወደምፁ፡ አቅርንት፨</l>

          </lg>
          
        </div>

        <div type="textpart" xml:id="tarafa-malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለከ፡ በጸጋ፡ አምላክከ፡ ወልድ፡ አምጣነ፡ አልቦ፡ ንስሐ፤</l>
            <l n="2">ጲላጦስ፡ ቦእከ፡ ቤተ፡ ፍሥሐ፨</l>
            <l n="3">ዘብርሃን፡ ሠርጐ፡ ሕንጼሃ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለከ፡ ብእሲትከ፡ አብሮቅላ፡ ወደቂቅከ፡ ፪ቱ፨</l>
            <l n="2">ጲላጦስ፡ ለወልድ፡ ሰማዕተ፡ ሞቱ፨</l>
            <l n="3">እምክብርከ፡ ኢተአተቱ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለከ፡ አፍቀሩከ፡ ጥቀ፡ ዳቅመ፨</l>
            <l n="2">ጸልኡከ፡ አርድእት፨</l>
            <l n="3">ሶበ፡ ቀሠፍኮ፡ ለወልድ፡ ውስተ፡ ዓውደ፡ ቅስት፡ ጲላጦስ፡ ሠናየ፡ ሀብት፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለከ፡ ክብረ፡ ዚአከ፡ ተነግረ፡ በአፈ፡ ማርያም፡ ድንግል፨</l>
            <l n="2">ጲላጦስ፡ ዘጾረከ፡ አርዑተ፡ መስቀል፨</l>
            <l n="3">ወፈጸምከ፡ ሥርዓተ፡ ቃል፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለከ፡ ለገማልያል፡ ዜናከ፡ ከመ፡ ተነግረ፡ እምቃሉ፨</l>
            <l n="2">ጲላጦስ፡ በጽድቅ፡ ልሳናት፡ ኵሉ፨</l>
            <l n="3">አዕበዩከ፡ ከመ፡ ይደሉ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለከ፡ ለኒቆዲሞስ፡ ወዮሴፍ፡ ዘገነዝዎ፡ በሥጋ፨</l>
            <l n="2">ጲላጦስ፡ ክብሮሙ፡ እንበለ፡ ንትጋ፨</l>
            <l n="3">አውረስከ፡ ቅዳሜ፡ ጸጋ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለከ፡ ለገባእት፡ ዓስብ፡ አመ፡ ይትወሀቦሙ፡ ድኅረ፨</l>
            <l n="2">ጲላጦስ፡ ኪያከ፡ በዘአክበረ፨</l>
            <l n="3">አማሕፀንኩከ፡ ኢትርሳዕ፡ ፍቅረ፨</l>
            <l n="4">ተሀበኒ፡ አሐተ፡ ዲናረ፨</l>

          </lg>
          
        </div>
        
      </div>
    </body>
    
