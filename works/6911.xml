  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ናሁ፡ ለልብየ፡ አስተናሥኦ፡ ዘመኑ፨</l>
            <l n="2">ዜና፡ መልክእኪ፡ ዓለም፡ ከመ፡ እጽሐፍ፡ ዘበበ፡ በይኑ፨</l>
            <l n="3">ባሕቱ፡ ሐሰተ፡ ከመ፡ ኢይቶስሕ፡ ውስተ፡ ድርሳኑ፨</l>
            <l n="4">ኢየሱስ፡ ክርስቶስ፡ ለእግዚአብሔር፡ የማኑ፨</l>
            <l n="5">ጸጋ፡ መንፈስ፡ ቅዱስ፡ ላዕሌየ፡ ይፈኑ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ውስተ፡ አፈ፡ አብዳን፡ ጥዑም፨</l>
            <l n="2">በአፈ፡ ማእምራን፡ እኪተ፡ ጽዋዔ፡ ዓለም፨</l>
            <l n="3">እለ፡ ግሑሳን፡ እማኅበርኪ፡ ዘሥጋ፡ ወደም፨</l>
            <l n="4">ኢየሐምዩ፡ ማኅሌትየ፡ ሶበ፡ ይብሉኪ፡ ሰላም፨</l>
            <l n="5">እስመ፡ በውስቴቱ፡ ዘለፋ፡ ወብዙኅ፡ መርገም፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለሥዕርተ፡ ርእስኪ፡ እለ፡ ተቀብአ፡ መዐዛ፨</l>
            <l n="2">ለነፍሰ፡ አብዳን፡ ዘይሔውዛ፨</l>
            <l n="3">አረጊት፡ ዓለም፡ ዘታስተሐውዚ፡ ፍቅረ፡ ወሬዛ፨</l>
            <l n="4">ኢይኩን፡ ድዉየ፡ ወሕሙመ፡ ለሥራይኪ፡ በሕምዛ፨</l>
            <l n="5">ዐቃቢተ፡ ሥራይ፡ ማርያም፡ ትኩነኒ፡ ቤዛ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለርእስኪ፡ እንተ፡ እምኔሁ፡ አስተርአዩ፨</l>
            <l n="2">ለሥጋ፡ ኃጢአት፡ መለያልዩ፨</l>
            <l n="3">ማኅደረ፡ እኩያን፡ ዓለም፡ ወለመልአኮሙ፡ ቤተ፡ እከዩ፨</l>
            <l n="4">ጻድቃንሰ፡ እለ፡ እማሕፀን፡ ተኀርዩ፨</l>
            <l n="5">ከመ፡ ኢየሀልዉ፡ ውስቴትኪ፡ ማኅደረ፡ ሌላዩ፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለገጽኪ፡ እንተ፡ አፍአሁ፡ ንጹሕ፨</l>
            <l n="2">ወውሳጤሁ፡ ርሱሕ፨</l>
            <l n="3">ረዳኢተ፡ ዲያብሎስ፡ ዓለም፡ ወንዋየ፡ ሐቅሉ፡ መፍርህ፨</l>
            <l n="4">ዘኢቈስለ፡ በሐጽኪ፡ ወመጥባሕትኪ፡ በሊኅ፨</l>
            <l n="5">አልቦ፡ ጠቢብ፡ ወአልቦ፡ የዋህ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለቀራንብትኪ፡  ዘነበስባሶን፡ አዖቀ፨</l>
            <l n="2">ምግባረ፡ ዘማዊት፡ ብእሲት፡ ማእከለ፡ ወራዙት፡  ረፈቀ፨</l>
            <l n="3">ማኅደረ፡  አብዳን፡ ዓለም፡ እንተ፡ ለመድኪ፡ ስላቀ፨</l>
            <l n="4">ምስሌኪ፡ ሰብእ፡ ማእምራን፡ ኢሀለወ፡ ልጹቀ፨</l>
            <l n="5">ነበሩ፡ በገዳም፡ ወቀነቱ፡ ሠቀ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለማኅቶተ፡ ሥጋኪ፡ እንተ፡ ኀረየ፡ ወአብደረ፨</l>
            <l n="2">መትሕተ፡ ዐራት፡ ይንበር፡ ወይከድንዎ፡ ከፈረ፨</l>
            <l n="3">ዕውርተ፡ አዕይንት፡ ዓለም፡ ዘትመርሒ፡ ዕዉረ፨</l>
            <l n="4">ክልኤክሙ፡ ትትዐቀፉ፡ ወትትወደቁ፡ ኅቡረ፨</l>
            <l n="5">ከመ፡ ዜናክሙ፡ አማናዊ፡ በወንጌል፡ ተነግረ፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ሰላም፡ ለአእዛንኪ፡ ዐውያተ፡ ነዳያን፡ ዘይጸመማ፨</l>
            <l n="2">ወእለ፡ ይሰምዓ፡ በጻህቅ፡ ውስተ፡ ቤተ፡ ተውኔት፡ ማሕሌተ፡ ዜማ፨</l>
            <l n="3">ዓለመ፡ ሥጋ፡ ርግምት፡ ኅብስተ፡ ዕለትኪ፡ በሐፈ፡ ጻማ፨</l>
            <l n="4">ለምረርኪ፡ ደኃራዊት፡ ሶበ፡ አእመሩ፡ አቅማ፨</l>
            <l n="5">መነኑ፡ ጠቢባን፡ ለተድላኪ፡ ጣዕማ፨</l>

          </lg>
          
          <lg type="stanza" n="9">
            
            <l n="1">ሰላም፡ ለመላትሕኪ፡ ዘአሠነያ፡ ቂሐተ፨</l>
            <l n="2">ከመ፡ ያሠግራ፡ ነፍሳተ፨</l>
            <l n="3">እመ፡ ዘማውያን፡ ዓለም፡ ዘታፈቅሪ፡ ዝሙተ፨</l>
            <l n="4">እምግባርኪ፡ ሰይጣናዊ፡ ዘነፍሰ፡ ንጹሓን፡ አስሐተ፨</l>
            <l n="5">መንፈሰ፡ ቅዳሴ፡  ጰራቅሊጦስ፡ ይዕቀበኒ፡ ሊተ፨</l>

          </lg>
          
          <lg type="stanza" n="10">
            
            <l n="1">ሰላም፡ ለአእናፍኪ፡ እመዐዛ፡ አምበር፡ ወምስክ፨</l>
            <l n="2">እለ፡ ይረውጻ፡ ዘልፈ፡ ውስተ፡ ፍናወ፡ ሞት፡ ድሩክ፨</l>
            <l n="3">እኅተ፡ አርዌ፡ ምድር፡ ዓለም፡ ዘረገመኪ፡ አምላክ፨</l>
            <l n="4">ኢይክሀል፡ አውድቆትየ፡ እከየ፡ መስሐቲ፡ መልአክ፨</l>
            <l n="5">ከመ፡ አውደቀኪ፡ ቅድመ፡ እምሣልስ፡ ፈለክ፨</l>

          </lg>
          
          <lg type="stanza" n="11">
            
            <l n="1">ሰላም፡ ለከናፍርኪ፡ እለ፡ ኢይቶስሑ፡ ሕቀ፨</l>
            <l n="2">ውስተ፡ ንባቦሙ፡ ጽድቀ፨</l>
            <l n="3">መፍቀሪተ፡ ንዋይ፡ ዓለም፡ እንተ፡ ታስተጋብኢ፡ ወርቀ፨</l>
            <l n="4">ጻድቃንሰ፡ ለመዝገብኪ፡ ሶበ፡ አስቆረርዎ፡ ጥቀ፨</l>
            <l n="5">ኢነሥኡ፡ እምኔሁ፡ አሐተ፡ ጸሪቀ፨</l>

          </lg>
          
          <lg type="stanza" n="12">
            
            <l n="1">ሰላም፡ ለአፉኪ፡ ዘኢተዐቅበ፡ በሕግ፨</l>
            <l n="2">እስመ፡ አምሳለ፡ ቤት፡ ውእቱ፡ እንተ፡ አልባቲ፡ መንሠግ፨</l>
            <l n="3">ማኅፈደ፡ ኆፃ፡ ዘይገፍዑኪ፡ አፍላግ፨</l>
            <l n="4">ይባልሓ፡ በጸሎቱ፡ እምድቀትኪ፡ ፀዋግ፨</l>
            <l n="5">አብ፡ ቅዱስ፡ ያዕቆብ፡ ዘሥሩግ፨</l>

          </lg>
          
          <lg type="stanza" n="13">
            
            <l n="1">ሰላም፡ ለአስናንኪ፡ ዘበእንቲአሆን፡ ተጽሕፈ፨</l>
            <l n="2">አሌ፡ ሎሙ፡ እንዘ፡ ይብል፡ ለእለ፡ ይሥሕቁ፡ ዘልፈ፨</l>
            <l n="3">መሥገርተ፡ ኃጥኣን፡ ዓለም፡ ዘትሰመዪ፡ ገሪፈ፨</l>
            <l n="4">ወቦ፡ ጊዜ፡ አመ፡ ትትመሰሊ፡ ጸድፈ፨</l>
            <l n="5">ውስተ፡ ፍናዌሆሙ፡ ለጻድቃን፡ ትኩኒ፡ ማዕቅፈ፨</l>

          </lg>
          
          <lg type="stanza" n="14">
            
            <l n="1">ሰላም፡ ለልሳንኪ፡ እንተ፡ ትቀልል፡ እምኔሃ፨</l>
            <l n="2">ማኅደረ፡ ኃጥኣን፡ ሲኦል፡ ዘጽልመት፡ መናሥግቲሃ፨</l>
            <l n="3">ዐማፂት፡ ዓለም፡ ለምኵናንኪ፡ በዐውደ፡ ፍትሓ፨</l>
            <l n="4">እንዘ፡ ጻድቀ፡  ትኴንኒ፡ ወትረስሒ፡ ንጹሐ፨</l>
            <l n="5">ጐንደየ፡ መዋዕል፡ ወዘመን፡ ኖኀ፨</l>

          </lg>
          
          <lg type="stanza" n="15">
            
            <l n="1">ሰላም፡ ለቃልኪ፡ እምብሂለ፡ ነገር፡ ዘኢያርመመ፨</l>
            <l n="2">ንብላዕ፡ ወንስተይ፡ እስመ፡ ንመውት፡ ጌሰመ፨</l>
            <l n="3">መፍቀሪተ፡ ሀከክ፡ ዓለም፡ ዘትጸልኢ፡ ሰላመ፨</l>
            <l n="4">እምታውፅኢ፡ ዘንተ፡ እምአፉኪ፡ ቃለ፡ አእምሮ፡ ሕሡመ፨</l>
            <l n="5">ይኄይስ፡ እምውስቴቱ፡ ትደዪ፡ ልጓመ፨</l>

          </lg>
          
          <lg type="stanza" n="16">
            
            <l n="1">ሰላም፡ ለእስትንፋስኪ፡ ለነፍሰ፡ ፀጋም፡ ዘይመስሎ፨</l>
            <l n="2">እስመ፡ ንፍኀቱ፡ ዕሩቅ፡ እምጥዒና፡ ሰብእ፡ ወተሣህሎ፨</l>
            <l n="3">ኦዓለም፡ ሀገረ፡ ጽልሑት፡ ወተበቅሎ፨</l>
            <l n="4">ተብህለ፡ በእንቲአሁ፡ አሌሎ፡ አሌሎ፨</l>
            <l n="5">ውስተ፡ ዐጸድኪ፡ ዐጸደ፡ ሀጕል፡ ለብእሲ፡ ዘሀሎ፨</l>

          </lg>
          
          <lg type="stanza" n="17">
            
            <l n="1">ሰላም፡ ለጕርዔኪ፡ ዘጥዑመ፡ ኮነ፡ በኀቤሁ፨</l>
            <l n="2">እምነ፡ ኵሎ፡ ጣዕማት፡ ፍቅረ፡ ወራዙት፡ አዕርክቲሁ፨</l>
            <l n="3">ለዕለተ፡ ፍዳኪ፡ እመ፡ ተጐናደየ፡ መዋዕሊሁ፨</l>
            <l n="4">ኢይመስለኪ፡ ዘትድኅኒ፡ ወታመሥጢ፡ እምፍትሑ፨</l>
            <l n="5">በመድረከ፡ ኆኅት፡ ቀዊሞ፡ ናሁ፨</l>

          </lg>
          
          <lg type="stanza" n="18">
            
            <l n="1">ሰላም፡ ለክሳድኪ፡ ዘመልዕልተ፡ መትከፍ፡ መንበሩ፨</l>
            <l n="2">ወእደ፡ ወራዙት፡ መጾሩ፨</l>
            <l n="3">ዘማዊት፡ ዓለም፡ ለሰይጣን፡ ዝሙት፡ ማኅደሩ፨</l>
            <l n="4">ጻድቃንሰ፡ እለ፡ ጥበበ፡ መከሩ፨</l>
            <l n="5">ከመ፡ ኢይርአዩኪ፡ ውስተ፡ ጸድፍ፡ ርእሶሙ፡ ወገሩ፨</l>

          </lg>
          
          <lg type="stanza" n="19">
            
            <l n="1">ሰላም፡ ለመታክፍትኪ፡ እለ፡ ገደፋሁ፡ በትዕቢት፨</l>
            <l n="2">ለቀሊል፡ ጾር፡ ወለሠናይ፡ አርዑት፨</l>
            <l n="3">ገፋዒት፡ ዓለም፡ በዓልተ፡ አባግዕ፡ እሞት፨</l>
            <l n="4">እፎ፡ ሄድከኒ፡ ለዘአልብየ፡ እንበለ፡ አሐቲ፡ በግዕት፨</l>
            <l n="5">ለምንትኑ፡ ላዕሌኪ፡ ኢይዘንም፡ እሳት፨</l>

          </lg>
          
          <lg type="stanza" n="20">
            
            <l n="1">ሰላም፡ ለዘባንኪ፡ ሞጣሕተ፡ ዘማ፡ ተዐጺፎ፨</l>
            <l n="2">ለምግባረ፡ ዝሙት፡ ተሳተፎ፨</l>
            <l n="3">እንተ፡ ኢተአምሪ፡ ዓለም፡ ጊዜ፡ ተራሕቆት፡ ወተሐቅፎ፨</l>
            <l n="4">ላዕለ፡ ዮሴፍ፡ ንጹሐ፡ ነፍስ፡ ተሐበልኪ፡ እፎ፨</l>
            <l n="5">እስከ፡ ጐየ፡ አልባስኪ፡  በእዴኪ፡ ገዲፎ፨</l>

          </lg>
          
          <lg type="stanza" n="21">
            
            <l n="1">ሰላም፡ ለእንግድዓኪ፡ እንተ፡ ወለጠ፡ ሕበሪሁ፨</l>
            <l n="2">በኪነ፡ አብዳን፡ አንስት፡ እመልክአ፡ ፍጥረት፡ ዘቀዳሚሁ፨</l>
            <l n="3">ኀዳጊተ፡ ፍቅር፡ ዓለም፡ ወወላጢተ፡ ዐርክ፡ ለለ፡ ጽባሑ፨</l>
            <l n="4">እምነግህ፡ እስከ፡ ሠርክ፡ ከመ፡ ተጽሕፈ፡ ዜናሁ፨</l>
            <l n="5">ይትዐለው፡ መንበርትኪ፡ ወይትፋለስ፡ ናሁ፨</l>

          </lg>
          
          <lg type="stanza" n="22">
            
            <l n="1">ሰላም፡ ለሕፅንኪ፡እንተ፡ ውስቴቱ፡ ረፈቁ፨</l>
            <l n="2">ማኅበረ፡ ኃጥኣን፡ ሰብእ፡ እለ፡ በኃጢአት፡ ልህቁ፨</l>
            <l n="3">ዐላዊተ፡ ክርስቶስ፡ ዓለም፡ ወመስተቃርንት፡ ምስለ፡ ደቂቁ፨</l>
            <l n="4">ኀዲጎ፡ አልባስ፡ ዘሥሩዕ፡ ሶበ፡ ጸላዕኪ፡ በሕቁ፨</l>
            <l n="5">አባ፡ በርሱማ፡ ነበረ፡ ዕራቁ፨</l>

          </lg>
          
          <lg type="stanza" n="23">
            
            <l n="1">ሰላም፡ ለአእዳውኪ፡ እለ፡ ኢስፉሐት፡ እማንቱ፨</l>
            <l n="2">ከመ፡ ይምሐራ፡ ነዳየ፡ ወከመ፡ ይሠሀላ፡ ላዕለ፡ ንዴቱ፨</l>
            <l n="3">ድንጻዊት፡ ዓለም፡ ወኢመሓሪት፡ ለዘአልቦቱ፨</l>
            <l n="4">ለምንት፡ በከ፡ ትተግሂ፡ ወትጻምዊ፡ በከንቱ፨</l>
            <l n="5">እንዘ፡ ይወርሶ፡ ካልእ፡ ለብዕልኪ፡ ዝንቱ፨</l>

          </lg>
          
          <lg type="stanza" n="24">
            
            <l n="1">ሰላም፡ እብል፡ ለመዛርዕኪ፡  መንታ፨</l>
            <l n="2">እለ፡ ይትዐገላ፡ ዘልፈ፡ ንዋየ፡ ምስኪን፡ ወእጓለ፡ ማውታ፨</l>
            <l n="3">ከማኪ፡ ዓለም፡ እስመ፡ ይትዐጹ፡ አንቀጸ፡ ቤታ፨</l>
            <l n="4">ዘተወከፈት፡ አንጋደ፡ በመዋዕለ፡ ኵሉ፡ ሕይወታ፨</l>
            <l n="5">ብፅዕት፡ ይእቲ፡ መሓሪት፡ ማርታ፨</l>

          </lg>
          
          <lg type="stanza" n="25">
            
            <l n="1">ሰላም፡ ለኵርናዕኪ፡ በቅሩባኒሁ፡ ዘተኀየለ፨</l>
            <l n="2">ለነኪራንኪሰ፡  መዊኦቶሙ፡ ኢተሐበለ፨</l>
            <l n="3">ጸላዒተ፡ ነዳይ፡ ዓለም፡ ዘታፈቅሪ፡ ባዕለ፨</l>
            <l n="4">ኀጣእኩ፡ በእንቲአኪ፡ ወኢረከብኩ፡ አምሳለ፨</l>
            <l n="5">እንበለ፡ ሰይጣን፡ ወሞት፡ ዘነሥኡኪ፡ ክፍለ፨</l>

          </lg>
          
          <lg type="stanza" n="26">
            
            <l n="1">ሰላም፡ ለእመትኪ፡ መስፈርተ፡ ዐመፃ፡ ወአድልዎ፨</l>
            <l n="2">ዘአረፋቲሃ፡ ሰፈረ፡ ለማኅፈደ፡ ፍትወት፡ ወዘምዎ፨</l>
            <l n="3">ግሕሥተ፡ ህላዌ፡ ዓለም፡ እምፍኖተ፡ ፍቅር፡ ወተአኅዎ፨</l>
            <l n="4">ሌሊተ፡ ወፅአ፡ ገሪማ፡ ምግባራተኪ፡ ለቢዎ፨</l>
            <l n="5">ወአንቀጸ፡ ቤቱ፡ ክብርት፡ ኀደገ፡ አርኂዎ፨</l>

          </lg>
          
          <lg type="stanza" n="27">
            
            <l n="1">ሰላም፡ ለእራሓትኪ፡ እንተ፡ ዲቤሁ፡ ተለክአ፨</l>
            <l n="2">ኃጢአት፡ ለሞት፡ ቀኖቱ፡ እምቀኖተ፡ ኀጺን፡ ዘጸንዐ፨</l>
            <l n="3">እፎ፡ ዓለም፡ ኢተሐውሪ፡ ርቱዐ፨</l>
            <l n="4">እምፈሪሳውያን፡ ኅብስተ፡ ትትዐቀቢ፡ ወእምሰዱቃውያን፡ ብሑአ፨</l>
            <l n="5">አኮኑ፡ መምህረ፡ ሕግ፡ ላዕሌኪ፡ ሠርዐ፨</l>

          </lg>
          
          <lg type="stanza" n="28">
            
            <l n="1">ሰላም፡ ለአጻብዕኪ፡ እለ፡ ጠፊሐ፡ ለመዳ፨</l>
            <l n="2">በሕገ፡ ሰፋኒት፡ ብእሲት፡ ወለተ፡ እኅትኪ፡ ሄሮድያዳ፨</l>
            <l n="3">ቀታሊተ፡ ፍቅር፡ ዓለም፡ ወተመያኒት፡ እመ፡ ይሁዳ፨</l>
            <l n="4">እፎ፡ ይከውን፡ ፍርሀትኪ፡ አመ፡ ዕለተ፡ ግሩም፡ ፍዳ፨</l>
            <l n="5">ሶበ፡ መኳንንት፡ ላዕሌኪ፡ ይፈትሑ፡ ዕዳ፨</l>

          </lg>
          
          <lg type="stanza" n="29">
            
            <l n="1">ሰላም፡ ለአጽፋረ፡ እዴኪ፡ እለ፡ ወለጣሁ፡ ለሥራይ፨</l>
            <l n="2">[ኀበ፡ ኀላፊ፡ ንዋይ፨]</l>
            <l n="3">ዘመደ፡ አብዕልት፡ ዓለም፡ ወኢሕዝብኪ፡ ነዳይ፨</l>
            <l n="4">እስመ፡ አንቲ፡ ተመሰልኪዮ፡ ለመምህርኪ፡ ዕቡይ፨</l>
            <l n="5">ከመ፡ አውደቂዮ፡ አውደቁኪ፡ እምሣልስ፡ ሰማይ፨</l>

          </lg>
          
          <lg type="stanza" n="30">
            
            <l n="1">ሰላም፡ ለአጥባዕትኪ፡ እለ፡ ሐፀናሁ፡ እምናእስ፨</l>
            <l n="2">ለግዙፍ፡ ሕሊና፡ ወለዕቡይ፡ መንፈስ፨</l>
            <l n="3">ኦዓለም፡ ሐመረ፡ኃጢአት፡ ወርኵስ፨</l>
            <l n="4">መኑ፡ ይጌሥጽ፡ እምቅድሜየ፡ መዋግደ፡ ባሕርኪ፡ ባእስ፨</l>
            <l n="5">ወያበጽሕ፡ ኀበ፡ ዛሕን፡ ወመርስ፨</l>

          </lg>
          
          <lg type="stanza" n="31">
            
            <l n="1">ሰላም፡ ለገቦኪ፡ ነጺፈ፡ ዘርቤታት፡ ዘአደሞ፨</l>
            <l n="2">እንተ፡ ላዕሌሁ፡ ነስነሱ፡ መጽርየ፡ ወቀናንሞ፨</l>
            <l n="3">አመ፡ አቤሜሌክ፡ ጸለየ፡ በጥብዐተ፡ ልብ፡ አስተሐሚሞ፨</l>
            <l n="4">ተዋልጦትኪ፡ ዓለም፡ እስመ፡ ፈድፈደ፡ ገሪሞ፨</l>
            <l n="5">መዋዕለ፡ መቅሠፍትኪ፡ ዘአሜሃ፡ አኅላፈ፡ ነዊሞ፨</l>

          </lg>
          
          <lg type="stanza" n="32">
            
            <l n="1">ሰላም፡ ለከርሥኪ፡ እንተ፡ ህላዌሁ፡ አርኀበ፨</l>
            <l n="2">ለድዉየ፡ ሕሊና፡ ከመ፡ ይኩኖ፡ ምስካበ፨</l>
            <l n="3">ምግባረ፡ አብዕልትኒ፡ ይመስለኒ፡ ዕፁበ፨</l>
            <l n="4">እፎ፡ ይዘግብ፡ አሐዱ፡  ወኢይትራዳእ፡ ምንዱበ፨</l>
            <l n="5">እንዘ፡ አሐዱ፡ ይመውት፡ ኀዲጎ፡ መዝገበ፨</l>

          </lg>
          
          <lg type="stanza" n="33">
            
            <l n="1">ሰላም፡ ለልብኪ፡ ዘኢይሄሉ፡ በሰማይ፨</l>
            <l n="2">እስመ፡ ህላዌሁ፡ ረሰየ፡ ኀበ፡  ሀሎ፡ ንዋይ፨</l>
            <l n="3">በእንተ፡ ምግባርኪ፡ ዓለም፡ ማኅበረ፡ ኵሉ፡ እከይ፨</l>
            <l n="4">እግዚአብሔር፡ አጥፍኦ፡ ቀዳሜ፡ ፍጥረቱ፡ በማይ፨</l>
            <l n="5">ወአውዐዩ፡ መላእክት፡ በእሳት፡ ወተይ፨</l>

          </lg>
          
          <lg type="stanza" n="34">
            
            <l n="1">ሰላም፡ ለኵልያትኪ፡ ጊዜ፡ ፈተኖን፡ ፈጣሪ፨</l>
            <l n="2">እንተ፡ ውስቴቶን፡ ረከበ፡ ምግባረ፡ መሠርይ፡ ወተጠያሪ፨</l>
            <l n="3">ዓለመ፡ ሥጋ፡ ዘይእዜ፡ ወአኮ፡ ዘደኀሪ፨</l>
            <l n="4">ተግሕሡ፡ በእንተ፡ ዝንቱ፡ እምፍኖትኪ፡ መሥገሪ፨</l>
            <l n="5">አባ፡ እንጦኒ፡ ወአባ፡ መቃሪ፨</l>

          </lg>
          
          <lg type="stanza" n="35">
            
            <l n="1">ሰላም፡ ለሕሊናኪ፡ ዘኢይሔሊ፡ አሠንዮ፨</l>
            <l n="2">እስመ፡ ልማድኪ፡ ዓለም፡ ምግባረ፡ ትምይንት፡ ወአእከዮ፨</l>
            <l n="3">እግዚአብሔር፡ ታሕተ፡ አርዑትኪ፡ ሶበ፡ ርእዮ፨</l>
            <l n="4">እንዘ፡ ይወድቅ፡  እመንበሩ፡ በሃፈ፡ ገጹ፡ ሴስዮ፨</l>
            <l n="5">ወመስተገብረ፡ ብእሴ፡ ለንጉሥ፡ ረሰዮ፨</l>

          </lg>
          
          <lg type="stanza" n="36">
            
            <l n="1">ሰላም፡ ለአማዑትኪ፡ እሳተ፡ ቅንአት፡ ዘይበልዖ፨</l>
            <l n="2">መናኔ፡ መፍቅዳት፡ ብእሲ፡ ለጣዕመ፡ ተድላኪ፡ ሶበ፡ ይጸልኦ፨</l>
            <l n="3">ለሕሊና፡ ዚአየኒ፡ ሶበ፡ አፍቅሮትኪ፡ አስተናሥኦ፨</l>
            <l n="4">ጰራቅሊጦስ፡ ዜና፡ መንፈሰ፡  ጽድቅ፡ ዜና፡ ስምኪ፡ ያርስዖ፨</l>
            <l n="5">ከመ፡ ባህለ፡ ቅዱስ፡ አርሳኒ፡ ዘልቡ፡ ኢሞኦ፨</l>

          </lg>
          
          <lg type="stanza" n="37">
            
            <l n="1">ሰላም፡ ለንዋየ፡ ውስጥኪ፡ እንተ፡ እምኔሁ፡ ሠረጻ፨</l>
            <l n="2">ትዕቢት፡ ወቅንአት፡ ወሐሰት፡ ርእሰ፡ ዐመፃ፨</l>
            <l n="3">ታስተድኅረኒ፡ ዓለም፡ ለነፍስ፡ እምርዋጻ፨</l>
            <l n="4">ለዓለምየ፡ ደኃሪት፡ ዘነሣእክዋ፡ በዕፃ፨</l>
            <l n="5">ዐጻዌ፡ ኀዋኅው፡ ቅድሜየ፡ ኢይዕጹ፡ አንቀጻ፨</l>

          </lg>
          
          <lg type="stanza" n="38">
            
            <l n="1">ሰላም፡ ለሕንብርትኪ፡ እስከ፡ በውዳሴ፡ ዘከሮ፨</l>
            <l n="2">በዓለ፡ ማሕሌት፡ ሰሎሞን፡ ፍቅረ፡ ወለተ፡ ፈርዖን፡ ዘአገበሮ፨</l>
            <l n="3">ኦዓለም፡ ምልእተ፡ እበድ፡ በኢያእምሮ፨</l>
            <l n="4">ካልእሰ፡ ኢተዜነውኩ፡ ነገሮ፨</l>
            <l n="5">አምሳለ፡ ካልኣት፡ መለያልይ፡ ከመ፡ እዝክር፡ ነውሮ፨</l>

          </lg>
          
          <lg type="stanza" n="39">
            
            <l n="1">ሰላም፡ ለማሕፀንኪ፡ እንተ፡ እምኔሁ፡ ተነክሩ፨</l>
            <l n="2">ኃጥኣን፡ ዕደው፡ እለ፡ ኤሳው፡ ወማኅበሩ፨</l>
            <l n="3">ለተድላ፡ መንበርትኪ፡ ዓለም፡ እንተ፡ ተመውኡ፡ በጣዕመ፡ ፍቅሩ፨</l>
            <l n="4">ተብህለ፡ ቅድመ፡ እግሮሙ፡ አሕባለ፡ መሥገርት፡ ሠተሩ።</l>
            <l n="5">ወበፍኖቶሙ፡ የማናዊ፡  ዕቅፍተ፡ አንበሩ፨</l>

          </lg>
          
          <lg type="stanza" n="40">
            
            <l n="1">ሰላም፡ ለሐቌኪ፡ ዘኢደግደገ፡ በጾም፨</l>
            <l n="2">ከመ፡ ሐቌ፡ ጻድቅ፡ ዮሐንስ፡ እንተ፡ ቅናቱ፡ አዲም፨</l>
            <l n="3">አምሳለ፡ ኅልፈቱ፡ ለዕለት፡  ወተፋልሶቱ፡ ለሕልም፨</l>
            <l n="4">እምባቢሎን፡ እስከነ፡ ፋርስ፡ ዘተፋለስኪ፡ ዓለም፨</l>
            <l n="5">ወእምህየኒ፡ ኀለፍኪ፡ ኀበ፡ ጽርዕ፡ ወሮም፨</l>

          </lg>
          
          <lg type="stanza" n="41">
            
            <l n="1">ሰላም፡ ለአቍያጽኪ፡ ዘተመስሉ፡ በሐጺን፨</l>
            <l n="2">አመ፡ አስተርአዩ፡ በሕልም፡ ሥዕለ፡ አርባዕቱ፡ ሥልጣን፨</l>
            <l n="3">ኦዓለም፡ መሀደምተ፡ ላህይ፡ ወሥን፨</l>
            <l n="4">ነሢኦ፡ ኪያኪ፡ በእዴሁ፡ ከመ፡ ሐጸ፡ እሳት፡ ርሱን፨</l>
            <l n="5">ቀስቶ፡ ይዌስቅ፡ ወይነድፍ፡ ሰይጣን፨</l>

          </lg>
          
          <lg type="stanza" n="42">
            
            <l n="1">ሰላም፡ ለአብራክኪ፡ ዘኢተለዋ፡ ትምህርቶ፨</l>
            <l n="2">ለመምህረ፡ ሕግ፡ ክርስቶስ፡ እምህላዌ፡ አርድእት፡ በተአትቶ፨</l>
            <l n="3">ላዕለ፡ መዝራዕትኪ፡ ዓለም፡ ዘያሰምከ፡ መዝራዕቶ፨</l>
            <l n="4">በመልዕልተ፡ ኆፃ፡ ከመ፡ ዘሐነጸ፡ ቤቶ፨</l>
            <l n="5">በከ፡ ይተግህ፡ ወይጻሙ፡ ከንቶ፨</l>

          </lg>
          
          <lg type="stanza" n="43">
            
            <l n="1">ሰላም፡ ለአእጋርኪ፡ ዘየዐውዳ፡ መራሕብተ፨</l>
            <l n="2">ወበቤትኒ፡  ኢየዐርፉ፡ ንስቲተ፨</l>
            <l n="3">ሶበኒ፡ ፀርኪ፡ ወሬዛ፡ እንዘ፡ የኀልፉ፡ ፍኖተ፨</l>
            <l n="4">ነዓ፡ ናንገርግር፡ ትቤልዮ፡ ወናስተሐውዝ፡ ስዕመተ፨</l>
            <l n="5">መሥዋዕተ፡ ሰላምየ፡ ለዓለም፡ ወእኁየ፡ አንተ፨</l>

          </lg>
          
          <lg type="stanza" n="44">
            
            <l n="1">ሰላም፡ ለሰኮናኪ፡ እለ፡ ልማዶን፡ ረዊጽ፨</l>
            <l n="2">ውስተ፡ ፍና፡ ስሕተት፡ ወዳኅፅ፨</l>
            <l n="3">እኪተ፡ ውሳጤ፡ ዓለም፡ ወሠናይተ፡ አፍአ፡ በገጽ፨</l>
            <l n="4">ሶበ፡ ኢሀሎ፡ መንግሥትኪ፡ ወሥልጣንኪ፡ ሕፁፅ፨</l>
            <l n="5">ፈታዌ፡ ክህነት፡ ኮነ፡ ዖዝያን፡ ዘለምጽ፨</l>

          </lg>
          
          <lg type="stanza" n="45">
            
            <l n="1">ሰላም፡ ለመከየድኪ፡ እንተ፡ ልምላሜሁ፡ ሐዋዝ፨</l>
            <l n="2">እምቅኔ፡ ሥጋ፡ ወነፍስ፡ እስመ፡ ውእቱ፡ ግዑዝ፨</l>
            <l n="3">በዓልተ፡ ክሂል፡ ዓለም፡ ዘባሕርይኪ፡ ዐዚዝ፨</l>
            <l n="4">እስመ፡ ኮንኪ፡ ከመ፡ ሰይጠን፡ መሠረተ፡ ሀከክ፡ ወጋእዝ፨</l>
            <l n="5">እፎ፡ ነሣእኪ፡ ፍጥረተ፡ ዘሕምዝ፨</l>

          </lg>
          
          <lg type="stanza" n="46">
            
            <l n="1">ሰላም፡ ለአፃብዐ፡ እግርኪ፡ እለ፡ ይሰረገዋ፡ ወትረ፨</l>
            <l n="2">አክሊለ፡ ባሕርይ፡ ጸዐዳ፡ እንተ፡ ኢኮነ፡ ነኪረ፨</l>
            <l n="3">ባሕርየ፡ ፍጥረትኪ፡ ዓለም፡ እንዘ፡ ያኤምር፡ ፈጢረ፨</l>
            <l n="4">ሎቱ፡ ረሰየ፡ ፈጣሪ፡ ሰማየ፡ ሰማያት፡ መንበረ፨</l>
            <l n="5">ወእንተ፡ ውስቴታ፡ አስዋክ፡ ወሀበኪ፡ ምድረ፨</l>

          </lg>
          
          <lg type="stanza" n="47">
            
            <l n="1">ሰላም፡ ለአጽፋረ፡ እግርኪ፡ መልዕልተ፡ ዐሠርቱ፡ መራናት፨</l>
            <l n="2">እለ፡ ይጸድላ፡ ዘልፈ፡ ከመ፡ ማኅቶት፨</l>
            <l n="3">እኅተ፡ ሐሊባ፡ ዓለም፡ ዘልማድኪ፡ ዝሙት፨</l>
            <l n="4">ለወለትኪ፡ ኢሥህልት፡ ዘትእምርተ፡ ስማ፡ መቅሠፍት፨</l>
            <l n="5">መኑ፡ እምአድኀነኒ፡ ለብእሲ፡ ስሑት፨</l>

          </lg>
          
          <lg type="stanza" n="48">
            
            <l n="1">ሰላም፡ ለቆምኪ፡ እንተ፡ አርትዐ፡ አካሎ፨</l>
            <l n="2">አካለ፡ ውሳጤኪሰ፡ ለጠዋይ፡ ይመስሎ፨</l>
            <l n="3">መፍቀሪተ፡ ዝሙት፡ ዓለም፡ ጸላኢተ፡ ንጽሕ፡ ወተድንግሎ፨</l>
            <l n="4">ሠናየ፡ መከሩ፡ ለበድሮሙ፡ ኢይቁሙኪ፡ ማእከሎ፨</l>
            <l n="5">አእሩገ፡ ምኔት፡ ጠቢባን፡ ዘስማ፡ ሃሌሎ፨</l>

          </lg>
          
          <lg type="stanza" n="49">
            
            <l n="1">ሰላም፡ ለመልክእኪ፡ እለ፡ ዘከርነ፡ በምንታዌ፨</l>
            <l n="2">ዘውሳጤሁ፡ ምግባረ፡ ወዘአፍአሁ፡ ግጻዌ፨</l>
            <l n="3">መሥገርተ፡ አብዳን፡ ዓለም፡ በተድላ፡ መብልዕ፡ ወስርጋዌ፨</l>
            <l n="4">ጠቢባንሰ፡ የኀሥሡ፡ እማኅበርኪ፡ ፅማዌ፨</l>
            <l n="5">ወእምጥዒናኪ፡ ማእምራን፡ ያፈቅሩ፡ ደዌ፨</l>

          </lg>
          
          <lg type="stanza" n="50">
            
            <l n="1">ሰላም፡ ለፀአተ፡ ነፍስኪ፡ አመ፡ ምጽአቱ፡ ለእግዚእነ፨</l>
            <l n="2">እምድኅረ፡ አብጻሕኪ፡ ዓለም፡ ዘአካለ፡ ርስዓን፡ መጠነ፨</l>
            <l n="3">እስመ፡ አሜሃ፡ ትሰፍን፡ መንግሥተ፡ ሰማያት፡ ተስፋነ፨</l>
            <l n="4">ወኢይክሉ፡ አድኅኖተኪ፡ እለ፡ ተብህሉ፡ ጻድቃነ፨</l>
            <l n="5">ሱቱፋነ፡ ክብርኪ፡ ወብዕልኪ፡ ዘይማስን፡ ፍጡነ፨</l>

          </lg>
          
          <lg type="stanza" n="51">
            
            <l n="1">ሰላም፡ ለበድነ፡ ሥጋኪ፡ አምሳለ፡ ካልእት፡ አብድንት፨</l>
            <l n="2">ዘኢይረክቦ፡ ትንሣኤ፡ አመ፡ ተነፍሑ፡ አቅርንት፨</l>
            <l n="3">እኪተ፡ ርስዓን፡ ዓለም፡ ዘኀለፈኪ፡ ውርዙት፨</l>
            <l n="4">እንዘ፡ አንቲ፡ እቤራይት፡ በዓልተ፡ ሰብአ፡ ክረምት፨</l>
            <l n="5">ምስለ፡ ወራዙት፡ ማኅበረ፡ አጽናዕኪ፡ ለምንት፨</l>

          </lg>
          
          <lg type="stanza" n="52">
            
            <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋኪ፡ ዘኢይዌስኩ፡ ባቲ፨</l>
            <l n="2">እንበለ፡ ሰበን፡ አሐቲ፨</l>
            <l n="3">መዋቲት፡ ዓለም፡ ወኀዳጊተ፡ ብዕል፡ ለመዋቲ፨</l>
            <l n="4">እንዘ፡ ነአምር፡ ሙስናኪ፡ ወኅልፈተ፡ ብዕልኪ፡ ዛቲ፨</l>
            <l n="5">እፎ፡ የኀይጠነ፡ ፍቅርኪ፡ መስሐቲ፨</l>

          </lg>
          
          <lg type="stanza" n="53">
            
            <l n="1">ሰላም፡ ለመቃብርኪ፡ ውስተ፡ ውሳጤ፡ ልብ፡ ቂቁይ፨</l>
            <l n="2">ዘኢይከሥቶ፡ ርኅራኄ፡ እስመ፡ ማኅተሙ፡ እከይ፨</l>
            <l n="3">አስከሬነ፡ ወርቅ፡ ዓለም፡ ወመዝገበ፡ ብሩር፡ ጽሩይ፨</l>
            <l n="4">እስከ፡ ማእዜኑ፡ ተዐጽዊ፡ አንቀጸ፡ ኀላፊ፡ ንዋይ፨</l>
            <l n="5">እንዘ፡ በአፍአኪ፡ ዘልፈ፡ ይግዕር፡ ነዳይ፨</l>

          </lg>
          
          <lg type="stanza" n="54">
            
            <l n="1">ሰላም፡ ለፍልሰተ፡ ሥጋኪ፡ እምዝንቱ፡ ውስተ፡ ዝንቱ፨</l>
            <l n="2">ለዘያፈቅረኪ፡ ብእሲ፡ እንበለ፡ ትፈጽሚ፡ ዓቅመ፡ ፍትወቱ፨</l>
            <l n="3">እስክንድርኒ፡ ንጉሠ፡ አናስር፡ አርባዕቱ፨</l>
            <l n="4">እንዘ፡ የኀሥሥ፡ መፍቅዳተ፡ ከመ፡ ዘምኔት፡ አልቦቱ፨</l>
            <l n="5">ወእንበለ፡ ይጸግብ፡ እምኔኪ፡ ፈለሰት፡ ሕይወቱ፨</l>

          </lg>
          
          <lg type="stanza" n="55">
            
            <l n="1">[ዓለም፡] ፍቅርትየ፡ በአምኃ፡ ጕሕሉት፡ አማኅኩኪ፨</l>
            <l n="2">አምሳለ፡ ይሁዳ፡ ረድእኪ፨</l>
            <l n="3">ወቃለ፡ ዘለፋ፡ ቶሳሕኩ፡ በውስቴቱ፡ እንዘ፡ እጌሥጽ፡ ኪያኪ፨</l>
            <l n="4">እመ፡ ኢነሳ|ሕኪሰ፡ ወታጸንዒ፡ ልበኪ፨</l>
            <l n="5">መቅሠፍተ፡ ወኵነኔ፡ ትዘግቢ፡ ለኪ፨</l>

          </lg>
          
        </div>

        
        
      </div>
