  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስምከ፡ ዘመፍቀሬ፡ አምላክ፡ ተብህለ፨</l>
            <l n="2">ወለሥዕርትከ፡ ዖፍ፡ ዘገዳመ፡ መትከፍ፡ ዔለ፨</l>
            <l n="3">ፊላታዎስ፡ ሐረግ፡ እንተ፡ ትጸውር፡ አስካለ፨</l>
            <l n="4">ከመ፡ እስብከ፡ ውስተ፡ ዓለም፡ ዝክረ፡ ስምከ፡ ወንጌለ፨</l>
            <l n="5">ልብሰ፡ ተራድኦ፡ ከድነኒ፡ ወኩነኒ፡ ኃይለ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለርእስከ፡ ዘበኀበ፡ ኵሉ፡ ውዱስ፨</l>
            <l n="2">ወለመንክረ፡ ስን፡ ገጽከ፡ ገጸ፡ ማሕየዊ፡ ክርስቶስ፨</l>
            <l n="3">ፊላታዎስ፡ ዛኅን፡ ፊላታዎስ፡ መርስ፨</l>
            <l n="4">እግዚኦ፡ ኩነኒ፡ ለገብርከ፡ ምዕራፈ፡ ሥጋ፡ ወነፍስ፨</l>
            <l n="5">እምነ፡ ማዕበላ፡ ጌጋይ፡ ለዓለም፡ ተርሴስ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለቀራንብቲከ፡ ቀራንብተ፡ ዳዊት፡ ቢጽ፨</l>
            <l n="2">ወለአዕይንቲከ፡ ሰላም፡ማኅትወ፡ ተቅዋም፡ ገጽ፨</l>
            <l n="3">ፊላታዎስ፡ ጽኑዕ፡ በትረ፡ ሃይማኖት፡ ቅሩጽ፨</l>
            <l n="4">ተቀጥቀጡ፡ በሥልጣንከ፡ አማልክተ፡ ንጉሥ፡ ሕጹጽ፨</l>
            <l n="5">ስብኮ፡ ዘእብን፡ ወግልፎ፡ ዘዕፅ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለአእዛኒከ፡ ምስለ፡ ሰሚዐ፡ ጽድቅ፡ ዘተዋሐዳ፨</l>
            <l n="2">ሠናያነ፡ ቂሐት፡ እምጽጌ፡ ረዳ፨</l>
            <l n="3">ፊላታዎስ፡ ኀያል፡ እጓለ፡ አንበሳ፡ ይሁዳ፨</l>
            <l n="4">እምጣኅርከ፡ መንፈሳዊት፡ ላህመ፡ ኀጢአት፡ ወዕዳ፨</l>
            <l n="5">ለአንጾኪያ፡ ርስትከ፡ ኢቆመ፡ በዐውዳ፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለአእናፊከ፡ መዛግብተ፡ ጼና፡ ብሩር፨</l>
            <l n="2">ወለከናፍሪከ፡ አፅማረ፡ ነቢብ፡ ባሕር፨</l>
            <l n="3">ፊላታዎስ፡ ሕፃን፡ ወወሬዛ፡ ዕድሜ፡ ሕጹር፨</l>
            <l n="4">አምላኪየ፡ ሶበ፡ ትቤሎ፡ ለዘ፡ እንዘ፡ ዋሕድ፡ በኵር፨</l>
            <l n="5">እምሃይማኖትከ፡ ተፈሥሕት፡ ምድር፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለአፉከ፡ እምነቢበ፡ ሐሳት፡ ዘተዐቅበ፨</l>
            <l n="2">ወለአስናኒከ፡ ሰላም፡ ዘተመንደቡ፡ ዕጹበ፨</l>
            <l n="3">ፊላታዎስ፡ ጸጋ፡ መጠነ፡ ለከ፡ ተውህበ፨</l>
            <l n="4">ለወልድከ፡ እጓለ፡ ማውታ፡ ከመ፡ ቃለ፡ መጽሐፍ፡ ነበበ፨</l>
            <l n="5">ጊዜ፡ ወርኀ፡ ተጽናስ፡ ኩነኒ፡ ዘየዐቅብ፡ አበ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለልሳንከ፡ ዘበእንተ፡ ክርስቶስ፡ ምቱር፨</l>
            <l n="2">ወለሐዋርያ፡ ቃልከ፡ መምህረ፡ ሰላም፡ ወፍቅር፨</l>
            <l n="3">ፊላታዎስ፡ ሰማዕት፡ ውስተ፡ ዐውደ፡ ንጉሥ፡ ኅሡር፨</l>
            <l n="4">ሥቃይከ፡ ዘተወከፍከ፡ ወምንዳቤከ፡ መንክር፨</l>
            <l n="5">ፈታሔ፡ ይኩነኒ፡ እምሲኦል፡ ማዕሠር፨</l>

          </lg>
          
          <lg type="stanza" n="8">
            
            <l n="1">ሰላም፡ ለእስትንፋስከ፡ እስትንፋሰ፡ ክብር፡ ወብዕል፨</l>
            <l n="2">ወለዘጥዕም፡ ጕርዔከ፡ ንባበ፡ መለኮት፡ ወንጌል፨</l>
            <l n="3">ፊላታዎስ፡ ክቡር፡ ወሬዛ፡ መንክራት፡ ወኀይል፨</l>
            <l n="4">ለአቡከ፡ መምላኬ፡ ላህም፡ ድኅረ፡ አመንደበቶ፡ ሐጕል፨</l>
            <l n="5">በጸሎተ፡ ሥሙር፡ ቃልከ፡ ከደነቶ፡ ሣህል፨</l>

          </lg>
          
          <lg type="stanza" n="9">
            
            <l n="1">ሰላም፡ ለክሳድከ፡ ዘይመስል፡ ቀርነ፡ ነጌ፨</l>
            <l n="2">ወለመትከፍትከ፡ ገነት፡ ሥርግወ፡ ሥዕርትከ፡ ግጼ፨</l>
            <l n="3">ፊላታዎስ፡ ነቢይ፡ መምግረ፡ እስራኤል፡ ሐጌ፨</l>
            <l n="4">ፀመውከ፡ እንበለ፡ ዐቅም፡ እንዘ፡ ትከውን፡ ሐጋጌ፨</l>
            <l n="5">ሕገ፡ ሕንጻ፡ መቅደሰ፡ ገድል፡ ዘአልቦ፡ ኑታጌ፨</l>

          </lg>
          
          <lg type="stanza" n="10">
            
            <l n="1">ሰላም፡ ለዘባንከ፡ ዘልብሰ፡ ሞገስ፡ ተዐጽፈ፨</l>
            <l n="2">ወለእንግድዓከ፡ ሰላም፡ ዘሕፅነ፡ ሥቃይ፡ ሐቀፈ፨</l>
            <l n="3">ፊላታዎስ፡ ኀያል፡ ከመ፡ ታስተፃንዕ፡ እልፈ፨</l>
            <l n="4">እስመ፡ ደክመ፡ ሶበ፡ አኀዝኮ፡ እንዘ፡ ያሠርፅ፡ አክናፈ፨</l>
            <l n="5">ህላዌ፡ ጣዖት፡ ዘልህም፡ ተመስለ፡ ዖፈ፨</l>

          </lg>
          
          <lg type="stanza" n="11">
            
            <l n="1">ሰላም፡ ለሕፅንከ፡ ሕፅነ፡ ተቀንዮ፡ ወተልእኮ፨</l>
            <l n="2">ወለእዴከ፡ ዘጸንዐ፡ ለእሒዝ፡ ቀርነ፡ ስብኮ፨</l>
            <l n="3">ፊላታዎስ፡ ምእመን፡ ለፀሓይ፡ ሶበ፡ አምሐልኮ፨</l>
            <l n="4">ከመ፡ ትክሥት፡ ቅድመ፡ አእላፍ፡ ዘአምላክከ፡ አምልኮ፨</l>
            <l n="5">ከመ፡ አምላክ፡ ጽድቅ፡ ኢኮነ፡ በቃሉ፡ አእመንኮ፨</l>

          </lg>
          
          <lg type="stanza" n="12">
            
            <l n="1">ሰላም፡ ለመዛርዒከ፡ መሳውቅተ፡ መትከፍ፡ ማኅፈድ፨</l>
            <l n="2">ወለኵርናዕከ፡ ጽኑዕ፡ እብነ፡ አድማስ፡ ክቡድ፨</l>
            <l n="3">ፊላታዎስ፡ ኅሩይ፡ ተረፈ፡ ኅሩያን፡ አንጋድ፨</l>
            <l n="4">ክብርከ፡ እስመ፡ ብዙኅ፡ ወመጠነ፡ ኆፃ፡ በፍቅድ፨</l>
            <l n="5">ያስተበፅዑከ፡ አእላፍ፡ ትውልድ፨</l>

          </lg>
          
          <lg type="stanza" n="13">
            
            <l n="1">ሰላም፡ ለእመትከ፡ ዘፍትው፡ ርእየቱ፨</l>
            <l n="2">ወለእራኃቲከ፡ ፪፡ ዘአእዳዊከ፡ ፪ቱ፨</l>
            <l n="3">ፊላታዎስ፡ ለወልድ፡ ሰማዕተ፡ ሕማሙ፡ ወሞቱ፨</l>
            <l n="4">ዕበየከ፡ ሶበ፡ ነጸሩ፡ ምስለ፡ አምዓት፡ ፱ቱ፨</l>
            <l n="5">በሃይማኖትከ፡ ጸንዑ፡ መሳፍንት፡ ፫፨</l>

          </lg>
          
          <lg type="stanza" n="14">
            
            <l n="1">ሰላም፡ እብል፡ ለአፃብዒከ፡ ኵሉ፨</l>
            <l n="2">ወለአጽፋሪከ፡ ዓዲ፡ እንዘ፡ ቃለ፡ ብፅዓን፡ አተሉ፨</l>
            <l n="3">ፊላታዎስ፡ ሰማዕት፡ ለዘለዓለም፡ ይሄሉ፨</l>
            <l n="4">ንጉሥ፡ ሶበ፡ ጸረፈ፡ መልዕልተ፡ ንባቡ፡ ወቃሉ፨</l>
            <l n="5">በትእዛዘ፡ ቃልከ፡ ብህመ፡ ወደክመ፡ እምኀይሉ፨</l>

          </lg>
          
          <lg type="stanza" n="15">
            
            <l n="1">ሰላም፡ ለገቦከ፡ በኲናተ፡ ሐራ፡ ዘተረፍዘ፨</l>
            <l n="2">ወለዘጸግበ፡ ከርሥከ፡ ኅብስተ፡ አእምሮ፡ ሐዋዘ፨</l>
            <l n="3">ፊላታዎስ፡ ወይን፡ ዘታስተፌሥሕ፡ ትኩዘ፨</l>
            <l n="4">ማየ፡ ሃይማኖት፡ ዘእምነቅዐ፡ ልብከ፡ ውሕዘ፨</l>
            <l n="5">እምግብርናተ፡ ሞት፡ ወሲኦል፡ እመከ፡ አግዐዘ፨</l>

          </lg>
          
          <lg type="stanza" n="16">
            
            <l n="1">ሰላም፡ ለልብከ፡ አድያመ፡ ጥበብ፡ ዘዖደ፨</l>
            <l n="2">ወለኵልያቲከ፡ አምላክ፡ ዘፈተኖን፡ ገሀደ፨</l>
            <l n="3">ፊላታዎስ፡ አንተ፡ ከመ፡ ትሣቀይ፡ ፈድፉደ፨</l>
            <l n="4">ላዕሌከ፡ እስመ፡ መከረ፡ እስከ፡ ቀቲሎቶ፡ ፈቀደ፨</l>
            <l n="5">ለዘያፈቅሮ፡ ንጉሥ፡ ኅርማኖስ፡ አብደ፨</l>

          </lg>
          
          <lg type="stanza" n="17">
            
            <l n="1">ሰላም፡ ለኅሊናከ፡ ሠናየ፡ ሥርዓት፡ ወሕግ፨</l>
            <l n="2">ውለአማዑቲከ፡ ሰላም፡ ዘማየ፡ ርኅራኄ፡ ፈለግ፨</l>
            <l n="3">ፊላታዎስ፡ ሙሴ፡ መስፍነ፡ እስራኤል፡ አእሩግ፨</l>
            <l n="4">ቀተልኮሙ፡ ከመ፡ ኀይልከ፡ ለእለ፡ ሴዎን፡ ወኦግ፨</l>
            <l n="5">ካህናተ፡ ጣዖት፡ አጵሎን፡ ላእከ፡ ሞት፡ ጸዋግ፨</l>

          </lg>
          
          <lg type="stanza" n="18">
            
            <l n="1">ሰላም፡ ለንዋየ፡ ውሥጥከ፡ ንዋየ፡ ሐዲስ፡ ሥርዓት፨</l>
            <l n="2">ወሰላም፡ ካዕበ፡ ለዘዚአከ፡ ኅንብርት፨</l>
            <l n="3">ፊላታዎስ፡ ፍቁር፡ ዐስበ፡ ገድልከ፡ እምርት፨</l>
            <l n="4">አብሰረከ፡ አምላከ፡ ጽድቅ፡ ምስለ፡ ፊቅጦር፡ ሰማዕት፨</l>
            <l n="5">ከመ፡ እንበለ፡ ሞት፡ ትነግሥ፡ በሐዳስ፡ መንግሥት፨</l>

          </lg>
          
          <lg type="stanza" n="19">
            
            <l n="1">ሰላም፡ ለሐቌከ፡ ጊዜ፡ ወርኀ፡ ሥቃይ፡ ዘጸንዐ፨</l>
            <l n="2">ወለአቍያጺከ፡ ፪፡ ዘግብረቶን፡ ተበፅዓ፨</l>
            <l n="3">ፊላታዎስ፡ ጥቀ፡ አነክር፡ ምስለ፡ ፍግዐ፨</l>
            <l n="4">ሄራቅሊስ፡ በትእዛዝከ፡ እስመ፡ አብያጺሁ፡ ጸውዐ፨</l>
            <l n="5">በትእዛዝከ፡ ጠፍኡ፡ ነገሥታት፡ ሰብዓ፨</l>

          </lg>
          
          <lg type="stanza" n="20">
            
            <l n="1">ሰላም፡ ለአብራኪከ፡ እለ፡ ታሕተ፡ ሐቌ፡ ሀለዉ፨</l>
            <l n="2">ወለአእጋሪከ፡ ሰላም፡ እለ፡ በፍና፡ ፈድል፡ ጻመዉ፨</l>
            <l n="3">ፊላታዎስ፡ ሙታን፡ ዘበጸሎትከ፡ ሐይዉ፨</l>
            <l n="4">ቅድሜሆሙ፡ ኢይርአዩከ፡ዐቅመ፡ በልቡና፡ ፈተው፨</l>
            <l n="5">ሐመደ፡ ሥጋከ፡ ሐራ፡ ውስተ፡ ባሕር፡ ዘረዉ፨</l>

          </lg>
          
          <lg type="stanza" n="21">
            
            <l n="1">ሰላም፡ ለሰኰናከ፡ ወለዘለከ፡ መከየድ፨</l>
            <l n="2">ፊላታዎስ፡ ብፁዕ፡ አክሊለ፡ እምከ፡ ጋድ፨</l>
            <l n="3">ኢያእመሩከ፡ ሐራ፡ እንዘ፡ ትትኴነን፡ በዐውድ፨</l>
            <l n="4">በከመ፡ ተብህለ፡ ሶበ፡ አእመሩ፡ አይሁድ፨</l>
            <l n="5">እምኢሰቀልዎ፡ ለክርስቶስ፡ ዋሕድ፨</l>

          </lg>
          
          <lg type="stanza" n="22">
            
            <l n="1">ሰላም፡ ለአፃብዒከ፡ በእሳተ፡ እቶን፡ አል፡ ኢነዱ፨</l>
            <l n="2">ወእምኔሆሙ፡ አጽፋር፡ አምሳለ፡ ደቂቅ፡ ተወልዱ፨</l>
            <l n="3">ፊላታዎስ፡ ጻድቅ፡ በይነ፡ ፍቅረ፡ አምላክ፡ አሐዱ፨</l>
            <l n="4">ብዙኃነ፡ አማልክተ፡ ታሕተ፡ ዕመቀ፡ ምድር፡ ይረዱ፨</l>
            <l n="5">በስመ፡ ክርስቶስ፡ አዘዝከ፡ ለንጉሥ፡ በዐውዱ፨</l>

          </lg>
          
          <lg type="stanza" n="23">
            
            <l n="1">ሰላም፡ ለቆምከ፡ ዘፍትው፡ አካሉ፨</l>
            <l n="2">ወለመልክእከ፡ አርዝ፡ ለዖፈ፡ ሥን፡ ምጽላሉ፨</l>
            <l n="3">ፊላታዎስ፡ ዕቁብ፡ ለሩፋኤል፡ በኀይሉ፨</l>
            <l n="4">ቅድሜሆሙ፡ ሶበ፡ አመንኮ፡ ለዘበሥላሴ፡ ይሄሉ፨</l>
            <l n="5">ሠራዊተ፡ ጣዖት፡ በበ፡ ንስቲት፡ ሥጋከ፡ ከፈሉ፨</l>

          </lg>
          
          <lg type="stanza" n="24">
            
            <l n="1">ሰላም፡ ለፀአተ፡ ነፍስከ፡ ከመ፡ ነፍሰ፡ አበው፡ ጻድቃን፨</l>
            <l n="2">ወለበድነ፡ ክቡር፡ ሥጋከ፡ ዘበነደእሳት፡ ኵኑን፨</l>
            <l n="3">ፊላታዎስ፡ ትንግሥ፡ እስመ፡ አልጸቀ፡ ዘመን፨</l>
            <l n="4">ለነፍስከ፡ አዕረግዋ፡ መላእክተ፡ ክርስቶስ፡ ብርሃን፨</l>
            <l n="5">ኀበ፡ አልቦ፡ ደዌ፡ ወአልቦ፡ ሕማም፡ ኀበ፡ አልቦቱ፡ ሞት፡ ወኀዘን፨</l>

          </lg>
          
          <lg type="stanza" n="25">
            
            <l n="1">ሰላም፡ ለግንዘተ፡ ሥጋከ፡ በእደ፡ ቅዱሳን፡ አኃው፨</l>
            <l n="2">ወለመቃብሪከ፡ ሰላም፡ በቃለ፡ ዝማሬ፡ ፍትው፨</l>
            <l n="3">ፊላታዎስ፡ ሰማዕት፡ ማእከለ፡ ሰማዕታት፡ ዕደው፨</l>
            <l n="4">አርፍቀኒ፡ ፍዳ፡ ፃመውኩ፡ ለማሕሌትከ፡ ህልው፨</l>
            <l n="5">አመ፡ በደብረ፡ ጽዮን፡ ሎሙ፡ ይነግሥ፡ ሕያው፨</l>

          </lg>
          
          <lg type="stanza" n="26">
            
            <l n="1">______ ውሑደ፡ ለሰላምከ፡ ሥሉጥ፨</l>
            <l n="2">ፊላታዎስ፡ ምዑዝ፡ ዘሐይቀ፡ ባሕረ፡ ገድል፡ ስግላጥ፨</l>
            <l n="3">ቅድመ፡ ገጸ፡ ዚአከ፡ ይኩን፡ ዕጹበ፡ ተውላጥ፡ ወሤጥ፨</l>
            <l n="4">አኮኑ፡ ተኣምር፡ እግዚኦ፡ መኰንነ፡ አፍአ፡ ወውሥጥ፨</l>
            <l n="5">ከመ፡ ለማርያ፡ ይቤላ፡ የአክል፡ ኅዳጥ፨</l>

          </lg>
          
        </div>

        <div type="textpart" xml:id="tarafa-malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለከ፡ ብርሃነ፡ ልቡና፡ ሀበኒ፡ ወፈውስ፡ ደዌ፡ ዘነፍስ፨</l>
            <l n="2">በከመ፡ ወሀብኮ፡ ብርሃነ፡ ለአውስፍዮስ፨</l>
            <l n="3">ወልደ፡ ሣህል፡ ፊላታዎስ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ ለከ፡ በክብረ፡ አብሎሲስ፡ ዐቢይ፡ ወካልኣኒሁ፡ ዐበይት፨</l>
            <l n="2">ኢያኅደገኮ፡ ገድለ፡ ኂጣነ፡ ነገሥት፨</l>
            <l n="3">ፊላታዎስ፡ ቢጸ፡ ሰማዕት፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለከ፡ እለ፡ወለዱከ፡ ሕዝብ፡ አዕበዩከ፡ ብዙኀ፨</l>
            <l n="2">እስመ፡ መህርኮሙ፡ አንተ፡ ሕገ፡ ንስሓ፨</l>
            <l n="3">ፊላታዎስ፡ ወልደ፡ ፍሥሓ፨</l>

          </lg>
          
          <lg type="stanza" n="4">
            
            <l n="1">ሰላም፡ ለከ፡ ለመሠርይ፡ አውረድኮ፡ መትሕተ፡ ዕሙቅ፡ መካን፨</l>
            <l n="2">ወበሃይማኖት፡ አጽደቀ፡ ነፍሰ፡ ኃጥኣን፨</l>
            <l n="3">ፊላታዎስ፡ ወልደ፡ ብፅዓን፨</l>

          </lg>
          
          <lg type="stanza" n="5">
            
            <l n="1">ሰላም፡ ለከ፡ አልቦ፡ ከማከ፡ ለንጉሥ፡ ዘበአእባን፡ ወገሮ፨</l>
            <l n="2">እምእለ፡ ሰማዕታት፡ ተለዉ፡ ለክርስቶስ፡ ፍቅሮ፨</l>
            <l n="3">ፊላታዎስ፡ ወልደ፡ አንክሮ፨</l>

          </lg>
          
          <lg type="stanza" n="6">
            
            <l n="1">ሰላም፡ ለከ፡ ፀሓይ፡ ወወርኅ፡ ወከዋክብት፡ ኵሎሙ፨</l>
            <l n="2">ፊላታዎስ፡ አንተ፡ ኢትእመኖሙ፨</l>
            <l n="3">አይድዑከ፡ ተፈጥሮቶሙ፨</l>

          </lg>
          
          <lg type="stanza" n="7">
            
            <l n="1">ሰላም፡ ለከ፡ በተራድኦትከ፡ አልፈ፡ ከመ፡ ትርድአኒ፡ ውትረ፨</l>
            <l n="2">ኩነኒ፡ ዐውቀ፡ ወማእምረ፨</l>
            <l n="3">ፊላታዎስ፡ ለከ፡ እስመ፡ ኮንኩ፡ ገብረ፨</l>
            <l n="4">ወልብየ፡ ኪያከ፡ አፍቀረ፨</l>

          </lg>
          
        </div>
        
      </div>
    </body>
    
