    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስምኪ፡ ዘአፍቅሮ፡ አምላክ፡ ዘትካተ፨</l>
            <l n="2">ወለሥዕርተ፡ ርእስኪ፡ ሰላም፡ ዘድላሌሁ፡ ተከሥተ፨</l>
            <l n="3">ማርያም፡ ለክርስቶስ፡ ዘቀባዕኪዮ፡ ዕፍረተ፨</l>
            <l n="4">መርሒኒ፡ ኦእግዝእትየ፡ እንተ፡ ይሤኒ፡ ፍኖተ፨</l>
            <l n="5">ወዘእምኵሉ፡ ይኤድም፡ ጽግዊኒ፡ ሀብተ፨</l>

          </lg>
          
