  <text>

    <body>
      <div type="edition" xml:lang="gez">

        

        <div type="textpart" xml:id="malke">
          
          <lg type="stanza" n="1">
            
            <l n="1">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ጥሙቅ፨</l>
            <l n="2">እብል፡ አንሰ፡ ገባእተ፡ ሥላሴ፡ እምርሑቅ፨</l>
            <l n="3">በገጸ፡ አዜብ፡ ወመስዕ፡ ወገጸ፡ ዐረብ፡ ወሠርቅ፨</l>
            <l n="4">በቅስተ፡ አፉየ፡ ሐጸ፡ ስሞሙ፡ ውሡቅ፨</l>
            <l n="5">ለነዲፈ፡ ዝኩ፡ መብረቅ፡ እምሰማይ፡ ውዱቅ፨</l>

          </lg>
          
          <lg type="stanza" n="2">
            
            <l n="1">ሰላም፡ እብል፡ ለአስማተ፡ ቅድስት፡ ሥላሴ፨</l>
            <l n="2">በአርአያሆሙ፡ ዘፈጠሩ፡ እመሬተ፡ ምድር፡ ብእሴ፨</l>
            <l n="3">ነሢእየ፡ በስመ፡ ሥላሴ፡ ሜሮነ፡ ቅዳሴ፨</l>
            <l n="4">ከይድ፡ በከመ፡ ሥላሴ፡ ዘባነ፡ አንበሳ፡ ወከይሴ፨</l>
            <l n="5">ለሥላሴሆሙ፡ አቄርብ፡ ውዳሴ፨</l>

          </lg>
          
          <lg type="stanza" n="3">
            
            <l n="1">ሰላም፡ ለዝክረ፡ ስሞሙ፡ በበ፡ ህላዌሁ፡ ወገጹ፨</l>
            <l n="2">አስማተ፡ ሥላሴ፡ ዘይሬስዮሙ፡ ይንፍጹ፨</l>
            <l n="3">ለእድውየ፡ ሳጥና፡ ወለመልአከ፡ ሞት፡ ቢጹ፨</l>
            <l n="4">ወበዘይበረብሮሙ፡ ሥረተ፡ ወድምፁ፨</l>
            <l n="5">በቀስተ፡ አፉየ፡ ኢይሰስል፡ ሐጹ፨</l>

          </lg>
          
          <lg type="stanza" n="23">
            
            <l n="1">ሰላም፡ ለጽሕምክሙ፡ ለሞገስ፡ ዘሤሞ፨</l>
            <l n="2">በመላትሐ፡ አዳም፡ አስተዐዲሞ፨</l>
            <l n="3">ዘፈጠርክሙ፡ ከካለ፡ ቆሞ፨</l>
            <l n="4">ይምኖ፡ ወጽግሞ፡ ከዋላሁ፡ ወፍጽሞ፨</l>
            <l n="5">ሥጋሁ፡ ወደሙ፡ ሥዕርቶ፡ ወጽሕሞ፨</l>

          </lg>
          
          <lg type="stanza" n="52">
            
            <l n="1">ሰላም፡ ለቆምክሙ፡ ለአዳም፡ ዘጸለሎ፨</l>
            <l n="2">በአምጣነ፡ እደው፡ ፫እንዘ፡ ይሜጥን፡ አክሎ፨</l>
            <l n="3">ሥላሴ፡ ቅረቡኒ፡ ለተሣህሎ፨</l>
            <l n="4">ለእለ፡ ይፃረሩኒ፡ በተባቅሎ፡ እንዘ፡ ያርእዮሙ፡ ኀይሎ፨</l>
            <l n="5">ለሥላሴሆሙ፡ ይግሕፎሙ፡ ዐውሎ፨</l>

          </lg>
          
          <lg type="stanza" n="59">
            
            <l n="1">ተዋሕዶቱ፡ ለመንፈስ፡ ቅዱስ፡ ከመዝ፡ ውእቱ፨</l>
            <l n="2">መንፈስ፡ አብኒ፡ ወመንፈስ፡ ወልድ፡ ውእቱ፨</l>
            <l n="3">ወፍጻሜ፡ ገጽኒ፡ ሥላሴ፡ ውእቱ፨</l>
            <l n="4">አእምሮቶሙ፡ ውእቱ፡ ወጥበቦሙ፡ ውእቱ፨</l>
            <l n="5">ዕመቀ፡ ምክሮሙ፡ ባሕቲቱ፡ የአምር፡ ውእቱ፨</l>

          </lg>
          
          <lg type="stanza" n="60">
            
            <l n="1">____ ባዕደ፡ ዘእንበሌሆሙ፡ አምላከ፨</l>
            <l n="2">አንሰ፡ እብል፡ በልብየ፡ ነግሀ፡ ወሰርከ፨</l>
            <l n="3">ሥሉስ፡ ቅዱስ፡ ዘአልብክሙ፡ ተውሳከ፨</l>
            <l n="4">በሉኒ፡ ሥላሴ፡ ስረይነ፡ ለከ፨</l>
            <l n="5">ኀጢአተ፡ ኵሎ፡ ዘገበርከ፨</l>

          </lg>
          
        </div>

        
        
      </div>
